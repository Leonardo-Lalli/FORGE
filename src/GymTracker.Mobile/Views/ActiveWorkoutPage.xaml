<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:GymTracker.Mobile.ViewModels"
    xmlns:models="clr-namespace:GymTracker.Mobile.Models"
    x:Class="GymTracker.Mobile.Views.ActiveWorkoutPage"
    x:DataType="vm:ActiveWorkoutViewModel"
    Title="WORKOUT">

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" BackgroundColor="{StaticResource Surface}">

        <!-- Header: plan name + timer + close -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Padding="20,16" ColumnSpacing="12">
            <Border Grid.Column="0" BackgroundColor="{StaticResource SurfaceContainer}"
                    StrokeShape="RoundRectangle 12" Padding="10" HeightRequest="40" WidthRequest="40">
                <Label Text="←" FontSize="18" TextColor="{StaticResource OnSurface}"
                       HorizontalOptions="Center" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding FinishWorkoutCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </Border>
            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                <Label Text="{Binding PlanName}" FontFamily="LexendBold" FontSize="18" FontAttributes="Bold"
                       TextColor="{StaticResource OnSurface}" />
                <Label Text="{Binding ElapsedTime}" FontFamily="InterRegular" FontSize="12"
                       TextColor="{StaticResource TextSecondary}" />
            </VerticalStackLayout>
            <Button Grid.Column="2" Text="SALVA" FontFamily="InterBold" FontSize="10"
                    TextColor="{StaticResource OnSecondary}" BackgroundColor="{StaticResource LimeGreen}"
                    CornerRadius="10" HeightRequest="36" Padding="12,0"
                    Command="{Binding SaveWorkoutPlanCommand}" />
        </Grid>

        <!-- Notification banner -->
        <Border Grid.Row="1" IsVisible="{Binding NotificationMessage, Converter={x:Null}}" 
                BackgroundColor="{StaticResource PrimaryContainer}"
                Padding="16,12" Margin="16,0" Opacity="0.95"
                StrokeShape="RoundRectangle 12">
            <Label Text="{Binding NotificationMessage}" FontFamily="InterRegular" FontSize="13"
                   TextColor="{StaticResource OnPrimaryContainer}" />
        </Border>

        <!-- Rest Timer (visible during rest) -->
        <Border Grid.Row="2" IsVisible="{Binding IsRestTimerActive}"
                BackgroundColor="{StaticResource SurfaceContainerHigh}"
                Padding="16,12" Margin="16,8"
                Stroke="{StaticResource LimeGreen}" StrokeThickness="1.5"
                StrokeShape="RoundRectangle 12">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="12">
                <HorizontalStackLayout Grid.Column="0" Spacing="8">
                    <Label Text="⏱" FontSize="20" VerticalOptions="Center" />
                    <Label Text="PAUSA" FontFamily="InterBold" FontSize="12"
                           TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                    <Label Text="{Binding RestTimerText}" FontFamily="LexendBold" FontSize="28" FontAttributes="Bold"
                           TextColor="{StaticResource LimeGreen}" VerticalOptions="Center" />
                </HorizontalStackLayout>
                <!-- Progress bar -->
                <Border Grid.Column="1" BackgroundColor="{StaticResource SurfaceContainer}"
                        StrokeShape="RoundRectangle 4" HeightRequest="8" WidthRequest="100" VerticalOptions="Center">
                    <Border BackgroundColor="{StaticResource LimeGreen}"
                            StrokeShape="RoundRectangle 4"
                            WidthRequest="{Binding RestTimerProgress}"
                            HeightRequest="8" HorizontalOptions="Start" />
                </Border>
                <Button Grid.Column="2" Text="SALTA"
                        FontFamily="InterBold" FontSize="10" TextColor="{StaticResource OnSecondary}"
                        BackgroundColor="{StaticResource AlertRed}" CornerRadius="8"
                        HeightRequest="32" Padding="10,0"
                        Command="{Binding SkipRestTimerCommand}" />
            </Grid>
        </Border>

        <!-- Exercise List -->
        <CollectionView Grid.Row="3" ItemsSource="{Binding Exercises}"
                        SelectionMode="None" Margin="0,4,0,0">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:WorkoutExercise">
                    <Border Style="{StaticResource CardFrame}"
                            BackgroundColor="{StaticResource SurfaceContainerHigh}"
                            Margin="16,4">
                        <VerticalStackLayout Spacing="10">
                            <!-- Exercise Header -->
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="8">
                                <Border Grid.Column="0" BackgroundColor="{StaticResource SurfaceContainer}"
                                        StrokeShape="RoundRectangle 10" WidthRequest="36" HeightRequest="36" Padding="0">
                                    <Label Text="{Binding Order}" FontFamily="LexendBold" FontSize="14"
                                           TextColor="{StaticResource Primary}"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="{Binding ExerciseName}" FontFamily="LexendBold" FontSize="15" FontAttributes="Bold"
                                           TextColor="{StaticResource OnSurface}" />
                                    <Label Text="{Binding BodyPart}" FontFamily="InterRegular" FontSize="11"
                                           TextColor="{StaticResource TextSecondary}" />
                                </VerticalStackLayout>
                                <!-- Move up/down -->
                                <Label Grid.Column="2" Text="▲" FontSize="12" TextColor="{StaticResource TextSecondary}"
                                       VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ActiveWorkoutViewModel}}, Path=MoveExerciseUpCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Label.GestureRecognizers>
                                </Label>
                                <Label Grid.Column="3" Text="▼" FontSize="12" TextColor="{StaticResource TextSecondary}"
                                       VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ActiveWorkoutViewModel}}, Path=MoveExerciseDownCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Label.GestureRecognizers>
                                </Label>
                                <!-- Remove -->
                                <Label Grid.Column="4" Text="✕" FontSize="14" TextColor="{StaticResource AlertRed}"
                                       VerticalOptions="Center" Margin="4,0,0,0">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ActiveWorkoutViewModel}}, Path=RemoveExerciseCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </Grid>

                            <!-- Sets -->
                            <CollectionView ItemsSource="{Binding Sets}" SelectionMode="None">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="models:ExerciseSet">
                                        <Border Padding="8,6" Margin="0,2"
                                                BackgroundColor="{StaticResource SurfaceContainer}"
                                                StrokeShape="RoundRectangle 8">
                                            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto"
                                                  ColumnSpacing="6">
                                                <Border Grid.Column="0" BackgroundColor="{StaticResource Primary}"
                                                        StrokeShape="RoundRectangle 6" WidthRequest="28" HeightRequest="28" Padding="0">
                                                    <Label Text="{Binding SetNumber}" FontFamily="InterBold" FontSize="11"
                                                           TextColor="{StaticResource OnPrimary}"
                                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                                </Border>
                                                <Label Grid.Column="1" Text="Serie" FontFamily="InterRegular" FontSize="12"
                                                       TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                                                <Button Grid.Column="2" Text="−" FontSize="14"
                                                        BackgroundColor="{StaticResource SurfaceContainerHigh}"
                                                        TextColor="{StaticResource TextPrimary}" WidthRequest="30" HeightRequest="30"
                                                        CornerRadius="6" Padding="0" />
                                                <Label Grid.Column="3" Text="{Binding Reps}" FontFamily="LexendBold" FontSize="14"
                                                       TextColor="{StaticResource OnSurface}"
                                                       HorizontalTextAlignment="Center" VerticalOptions="Center" />
                                                <Button Grid.Column="4" Text="+" FontSize="14"
                                                        BackgroundColor="{StaticResource SurfaceContainerHigh}"
                                                        TextColor="{StaticResource TextPrimary}" WidthRequest="30" HeightRequest="30"
                                                        CornerRadius="6" Padding="0" />
                                                <Label Grid.Column="5" Text="reps" FontFamily="InterRegular" FontSize="11"
                                                       TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
                                                <Button Grid.Column="6" Text="✓" FontSize="14"
                                                        BackgroundColor="{StaticResource LimeGreen}"
                                                        TextColor="{StaticResource OnSecondary}" WidthRequest="34" HeightRequest="30"
                                                        CornerRadius="6" Padding="0"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ActiveWorkoutViewModel}}, Path=CompleteSetCommand}"
                                                        CommandParameter="{Binding .}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>

                            <!-- Add set + Replace -->
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                <Border Grid.Column="0" BackgroundColor="{StaticResource SurfaceContainer}"
                                        StrokeShape="RoundRectangle 8" Padding="10,6">
                                    <Label FontFamily="InterBold" FontSize="11" TextColor="{StaticResource Primary}">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="+ Aggiungi serie" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ActiveWorkoutViewModel}}, Path=AddSetCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                </Border>
                                <Border Grid.Column="2" BackgroundColor="{StaticResource SurfaceContainer}"
                                        StrokeShape="RoundRectangle 8" Padding="10,6">
                                    <Label Text="🔄 Sostituisci" FontFamily="InterBold" FontSize="11"
                                           TextColor="{StaticResource TextSecondary}">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ActiveWorkoutViewModel}}, Path=ReplaceExerciseCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                </Border>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Add exercise button -->
        <Border Grid.Row="4" Margin="16,8,16,100"
                BackgroundColor="{StaticResource SurfaceContainerHigh}"
                Stroke="{StaticResource Primary}" StrokeThickness="1.5"
                StrokeShape="RoundRectangle 12" Padding="0" HeightRequest="56">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12"
                  HorizontalOptions="Center" VerticalOptions="Center">
                <Label Grid.Column="0" Text="+" FontSize="22" TextColor="{StaticResource Primary}" VerticalOptions="Center" />
                <Label Grid.Column="1" Text="Aggiungi esercizio" FontFamily="InterRegular" FontSize="15"
                       TextColor="{StaticResource Primary}" VerticalOptions="Center" />
                <Label Grid.Column="2" Text="{Binding Exercises.Count}" FontFamily="LexendBold" FontSize="14"
                       TextColor="{StaticResource TextSecondary}" VerticalOptions="Center" />
            </Grid>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding AddExerciseCommand}" />
            </Border.GestureRecognizers>
        </Border>

    </Grid>

</ContentPage>
