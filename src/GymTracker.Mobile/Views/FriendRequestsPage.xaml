<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:GymTracker.Mobile.ViewModels"
    x:Class="GymTracker.Mobile.Views.FriendRequestsPage"
    x:DataType="vm:FriendRequestsViewModel"
    Title="FriendRequests"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*" BackgroundColor="{DynamicResource Surface}">

        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Padding="24,16" BackgroundColor="{DynamicResource Surface}">
            <Border Grid.Column="0" BackgroundColor="{DynamicResource SurfaceContainer}"
                    StrokeShape="RoundRectangle 999" WidthRequest="40" HeightRequest="40" Padding="0"
                    Stroke="{DynamicResource OutlineVariant}" StrokeThickness="0.5">
                <Label Text="←" FontSize="16" TextColor="{DynamicResource OnSurfaceVariant}"
                       HorizontalOptions="Center" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </Border>
            <Label Grid.Column="1" Text="Friend Requests" FontFamily="SpaceGrotesk" FontSize="18" FontAttributes="Bold"
                   TextColor="{DynamicResource OnSurface}" HorizontalOptions="Center" VerticalOptions="Center" />
            <Label Grid.Column="2" Text="♥" FontSize="22" TextColor="{DynamicResource Primary}"
                   HorizontalOptions="Center" VerticalOptions="Center" />
        </Grid>

        <Grid Grid.Row="1">
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               HorizontalOptions="Center" VerticalOptions="Center"
                               Color="{DynamicResource Primary}" />
            <Label Text="Nessuna richiesta in sospeso" IsVisible="{Binding IsEmpty}"
                   FontFamily="Inter" FontSize="14" TextColor="{DynamicResource TextSecondary}"
                   HorizontalOptions="Center" VerticalOptions="Center" />

            <CollectionView ItemsSource="{Binding Requests}" Margin="0,8,0,100">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:FriendRequestItem">
                        <Border BackgroundColor="{DynamicResource SurfaceContainerLowest}" Margin="16,4"
                                StrokeShape="RoundRectangle 14" Stroke="{DynamicResource OutlineVariant}" StrokeThickness="1"
                                Padding="16">
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12">
                                <Border Grid.Column="0" BackgroundColor="{DynamicResource PrimaryContainer}"
                                        StrokeShape="RoundRectangle 999" WidthRequest="44" HeightRequest="44" Padding="0">
                                    <Label Text="{Binding FromName, StringFormat='{0:0}'}"
                                           FontFamily="SpaceGrotesk" FontSize="18" FontAttributes="Bold"
                                           TextColor="{DynamicResource Primary}"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="{Binding FromName}" FontFamily="SpaceGrotesk" FontSize="16" FontAttributes="Bold"
                                           TextColor="{DynamicResource OnSurface}" />
                                    <Label Text="Wants to follow you" FontFamily="Inter" FontSize="12"
                                           TextColor="{DynamicResource TextSecondary}" />
                                </VerticalStackLayout>
                                <Border Grid.Column="2" BackgroundColor="{DynamicResource Primary}"
                                        StrokeShape="RoundRectangle 10" Padding="14,8" HeightRequest="36">
                                    <Label Text="ACCEPT" FontFamily="Lexend" FontSize="11" FontAttributes="Bold"
                                           TextColor="{DynamicResource OnPrimary}" CharacterSpacing="1"
                                           VerticalOptions="Center">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FriendRequestsViewModel}}, Path=AcceptCommand}" CommandParameter="{Binding .}" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                </Border>
                                <Border Grid.Column="3" BackgroundColor="{DynamicResource SurfaceContainerHigh}"
                                        StrokeShape="RoundRectangle 10" Padding="14,8" HeightRequest="36"
                                        Stroke="{DynamicResource OutlineVariant}" StrokeThickness="1">
                                    <Label Text="✕" FontSize="14" TextColor="{DynamicResource OnSurfaceVariant}"
                                           HorizontalOptions="Center" VerticalOptions="Center">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FriendRequestsViewModel}}, Path=RejectCommand}" CommandParameter="{Binding .}" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </Grid>
</ContentPage>
