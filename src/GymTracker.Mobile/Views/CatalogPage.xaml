<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:GymTracker.Mobile.ViewModels"
    x:Class="GymTracker.Mobile.Views.CatalogPage"
    x:DataType="vm:CatalogViewModel"
    Title="Esercizi"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*" BackgroundColor="{StaticResource Surface}">

        <!-- Search + Title -->
        <VerticalStackLayout Grid.Row="0" Padding="20,16,20,8" Spacing="12">
            <Label Text="Catalogo Esercizi"
                   FontFamily="LexendBold" FontSize="22" FontAttributes="Bold"
                   TextColor="{StaticResource OnSurface}" />
            <SearchBar Placeholder="Cerca esercizio..."
                       Text="{Binding SearchText}"
                       SearchCommand="{Binding SearchCommand}"
                       BackgroundColor="{StaticResource SurfaceContainer}"
                       TextColor="{StaticResource OnSurface}"
                       PlaceholderColor="{StaticResource Outline}"
                       CancelButtonColor="{StaticResource Primary}" />
            <!-- Muscle Group Chips -->
            <FlexLayout Wrap="Wrap" JustifyContent="Start">
                <Border BackgroundColor="{StaticResource LimeGreen}"
                        StrokeShape="RoundRectangle 16" Padding="14,8" Margin="0,0,8,8">
                    <Label Text="Tutti"
                           FontFamily="InterBold" FontSize="12" FontAttributes="Bold"
                           TextColor="{StaticResource OnSecondary}" />
                </Border>
                <Border BackgroundColor="{StaticResource SurfaceContainer}"
                        StrokeShape="RoundRectangle 16" Padding="14,8" Margin="0,0,8,8">
                    <Label Text="Petto"
                           FontFamily="InterBold" FontSize="12" FontAttributes="Bold"
                           TextColor="{StaticResource TextSecondary}" />
                </Border>
                <Border BackgroundColor="{StaticResource SurfaceContainer}"
                        StrokeShape="RoundRectangle 16" Padding="14,8" Margin="0,0,8,8">
                    <Label Text="Schiena"
                           FontFamily="InterBold" FontSize="12" FontAttributes="Bold"
                           TextColor="{StaticResource TextSecondary}" />
                </Border>
                <Border BackgroundColor="{StaticResource SurfaceContainer}"
                        StrokeShape="RoundRectangle 16" Padding="14,8" Margin="0,0,8,8">
                    <Label Text="Spalle"
                           FontFamily="InterBold" FontSize="12" FontAttributes="Bold"
                           TextColor="{StaticResource TextSecondary}" />
                </Border>
                <Border BackgroundColor="{StaticResource SurfaceContainer}"
                        StrokeShape="RoundRectangle 16" Padding="14,8" Margin="0,0,8,8">
                    <Label Text="Braccia"
                           FontFamily="InterBold" FontSize="12" FontAttributes="Bold"
                           TextColor="{StaticResource TextSecondary}" />
                </Border>
                <Border BackgroundColor="{StaticResource SurfaceContainer}"
                        StrokeShape="RoundRectangle 16" Padding="14,8" Margin="0,0,8,8">
                    <Label Text="Gambe"
                           FontFamily="InterBold" FontSize="12" FontAttributes="Bold"
                           TextColor="{StaticResource TextSecondary}" />
                </Border>
                <Border BackgroundColor="{StaticResource SurfaceContainer}"
                        StrokeShape="RoundRectangle 16" Padding="14,8" Margin="0,0,8,8">
                    <Label Text="Addome"
                           FontFamily="InterBold" FontSize="12" FontAttributes="Bold"
                           TextColor="{StaticResource TextSecondary}" />
                </Border>
            </FlexLayout>
        </VerticalStackLayout>

        <!-- Exercise List -->
        <ScrollView Grid.Row="1" Padding="20,0,20,100">
            <VerticalStackLayout Spacing="8">

                <!-- Empty State -->
                <VerticalStackLayout IsVisible="{Binding IsEmptyState}"
                                     Spacing="16" Padding="0,40">
                    <Label Text="🔍" FontSize="48" HorizontalTextAlignment="Center" />
                    <Label Text="Cerca un esercizio"
                           FontFamily="LexendBold" FontSize="18" FontAttributes="Bold"
                           TextColor="{StaticResource OnSurface}"
                           HorizontalTextAlignment="Center" />
                    <Label Text="Sfoglia il catalogo di 1300+ esercizi"
                           FontFamily="InterRegular" FontSize="14"
                           TextColor="{StaticResource TextSecondary}"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <!-- Example exercises (placeholder, will be CollectionView with API data) -->
                <VerticalStackLayout Spacing="8"
                                     IsVisible="{Binding HasError, Converter={x:Null}}">
                    <!-- Exercise 1 -->
                    <Border Style="{StaticResource CardFrame}"
                            BackgroundColor="{StaticResource SurfaceContainerHigh}">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <Border Grid.Column="0"
                                    BackgroundColor="{StaticResource SurfaceContainer}"
                                    StrokeShape="RoundRectangle 12"
                                    WidthRequest="64" HeightRequest="64" Padding="0">
                                <Label Text="🏋️" FontSize="28"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                                <Label Text="Barbell Bench Press"
                                       FontFamily="LexendBold" FontSize="15" FontAttributes="Bold"
                                       TextColor="{StaticResource OnSurface}" />
                                <HorizontalStackLayout Spacing="8">
                                    <Border BackgroundColor="{StaticResource SurfaceContainer}"
                                            StrokeShape="RoundRectangle 8" Padding="8,3">
                                        <Label Text="Petto"
                                               FontFamily="InterBold" FontSize="10"
                                               TextColor="{StaticResource Primary}" />
                                    </Border>
                                    <Border BackgroundColor="{StaticResource SurfaceContainer}"
                                            StrokeShape="RoundRectangle 8" Padding="8,3">
                                        <Label Text="Bilanciere"
                                               FontFamily="InterBold" FontSize="10"
                                               TextColor="{StaticResource TextSecondary}" />
                                    </Border>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›" FontSize="24"
                                   TextColor="{StaticResource TextSecondary}"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Border>

                    <!-- Exercise 2 -->
                    <Border Style="{StaticResource CardFrame}"
                            BackgroundColor="{StaticResource SurfaceContainerHigh}">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <Border Grid.Column="0"
                                    BackgroundColor="{StaticResource SurfaceContainer}"
                                    StrokeShape="RoundRectangle 12"
                                    WidthRequest="64" HeightRequest="64" Padding="0">
                                <Label Text="🏋️" FontSize="28"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                                <Label Text="Incline Dumbbell Press"
                                       FontFamily="LexendBold" FontSize="15" FontAttributes="Bold"
                                       TextColor="{StaticResource OnSurface}" />
                                <HorizontalStackLayout Spacing="8">
                                    <Border BackgroundColor="{StaticResource SurfaceContainer}"
                                            StrokeShape="RoundRectangle 8" Padding="8,3">
                                        <Label Text="Petto"
                                               FontFamily="InterBold" FontSize="10"
                                               TextColor="{StaticResource Primary}" />
                                    </Border>
                                    <Border BackgroundColor="{StaticResource SurfaceContainer}"
                                            StrokeShape="RoundRectangle 8" Padding="8,3">
                                        <Label Text="Manubri"
                                               FontFamily="InterBold" FontSize="10"
                                               TextColor="{StaticResource TextSecondary}" />
                                    </Border>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›" FontSize="24"
                                   TextColor="{StaticResource TextSecondary}"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Border>

                    <!-- Exercise 3 -->
                    <Border Style="{StaticResource CardFrame}"
                            BackgroundColor="{StaticResource SurfaceContainerHigh}">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <Border Grid.Column="0"
                                    BackgroundColor="{StaticResource SurfaceContainer}"
                                    StrokeShape="RoundRectangle 12"
                                    WidthRequest="64" HeightRequest="64" Padding="0">
                                <Label Text="🏋️" FontSize="28"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                                <Label Text="Cable Crossover"
                                       FontFamily="LexendBold" FontSize="15" FontAttributes="Bold"
                                       TextColor="{StaticResource OnSurface}" />
                                <HorizontalStackLayout Spacing="8">
                                    <Border BackgroundColor="{StaticResource SurfaceContainer}"
                                            StrokeShape="RoundRectangle 8" Padding="8,3">
                                        <Label Text="Petto"
                                               FontFamily="InterBold" FontSize="10"
                                               TextColor="{StaticResource Primary}" />
                                    </Border>
                                    <Border BackgroundColor="{StaticResource SurfaceContainer}"
                                            StrokeShape="RoundRectangle 8" Padding="8,3">
                                        <Label Text="Cavi"
                                               FontFamily="InterBold" FontSize="10"
                                               TextColor="{StaticResource TextSecondary}" />
                                    </Border>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›" FontSize="24"
                                   TextColor="{StaticResource TextSecondary}"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Border>

                </VerticalStackLayout>

                <!-- Loading state -->
                <VerticalStackLayout IsVisible="{Binding IsBusy}"
                                     VerticalOptions="Center" Spacing="12" Padding="0,60">
                    <ActivityIndicator IsRunning="{Binding IsBusy}" />
                    <Label Text="Caricamento esercizi..."
                           FontFamily="InterRegular" FontSize="14"
                           TextColor="{StaticResource TextSecondary}"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <!-- Error state -->
                <VerticalStackLayout IsVisible="{Binding HasError}"
                                     VerticalOptions="Center" Spacing="12" Padding="0,40">
                    <Label Text="{Binding ErrorMessage}"
                           FontFamily="InterRegular" FontSize="14"
                           TextColor="{StaticResource AlertRed}"
                           HorizontalTextAlignment="Center" />
                    <Button Text="RIPROVA"
                            Style="{StaticResource SecondaryButton}"
                            HorizontalOptions="Center"
                            Command="{Binding RefreshCommand}" />
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
