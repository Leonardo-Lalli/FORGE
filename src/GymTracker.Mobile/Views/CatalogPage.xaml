<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:GymTracker.Mobile.ViewModels"
    x:Class="GymTracker.Mobile.Views.CatalogPage"
    x:DataType="vm:CatalogViewModel"
    Title="Esercizi">

    <Grid RowDefinitions="Auto,Auto,*" Padding="20" RowSpacing="16">

        <!-- Error state -->
        <VerticalStackLayout Grid.Row="0"
                             IsVisible="{Binding HasError}"
                             Spacing="8">
            <Label Text="{Binding ErrorMessage}"
                   Style="{StaticResource ErrorLabel}"
                   HorizontalTextAlignment="Center" />
            <Button Text="RIPROVA"
                    Style="{StaticResource SecondaryButton}"
                    HorizontalOptions="Center"
                    Command="{Binding RefreshCommand}" />
        </VerticalStackLayout>

        <!-- Search Bar -->
        <SearchBar Grid.Row="1"
                   Placeholder="Cerca esercizio..."
                   Text="{Binding SearchText}"
                   SearchCommand="{Binding SearchCommand}"
                   BackgroundColor="{StaticResource SurfaceContainer}"
                   TextColor="{StaticResource OnSurface}"
                   PlaceholderColor="{StaticResource Outline}"
                   CancelButtonColor="{StaticResource Primary}" />

        <!-- Main content -->
        <Grid Grid.Row="2">

            <!-- Loading -->
            <VerticalStackLayout IsVisible="{Binding IsBusy}"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="12">
                <ActivityIndicator IsRunning="{Binding IsBusy}" />
                <Label Text="Caricamento esercizi..."
                       Style="{StaticResource BodyMd}"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <!-- Empty state -->
            <VerticalStackLayout IsVisible="{Binding IsEmptyState}"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="16">
                <Label Text="🏋️" FontSize="48" HorizontalTextAlignment="Center" />
                <Label Text="Nessun esercizio trovato"
                       Style="{StaticResource H2Bold}"
                       HorizontalTextAlignment="Center" />
                <Label Text="Cerca un esercizio per nome o esplora per gruppo muscolare."
                       Style="{StaticResource EmptyStateLabel}" />
            </VerticalStackLayout>

            <!-- Success state placeholder -->
            <VerticalStackLayout IsVisible="{Binding HasData}"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="16">
                <Label Text="I gruppi muscolari appariranno qui"
                       Style="{StaticResource BodyMd}"
                       TextColor="{StaticResource TextSecondary}"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

        </Grid>
    </Grid>

</ContentPage>
