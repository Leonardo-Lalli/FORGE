<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:GymTracker.Mobile.ViewModels"
    x:Class="GymTracker.Mobile.Views.SocialPage"
    x:DataType="vm:SocialViewModel"
    Title="Social"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*" BackgroundColor="{DynamicResource Surface}">

        <!-- Title + Tab Chips -->
        <VerticalStackLayout Grid.Row="0" Padding="20,16,20,4" Spacing="10">
            <Label Text="Classifica"
                   FontFamily="OpenSansSemibold" FontSize="22" FontAttributes="Bold"
                   TextColor="{DynamicResource OnSurface}" />
            <HorizontalStackLayout Spacing="8">
                <Border BackgroundColor="{DynamicResource LimeGreen}"
                        StrokeShape="RoundRectangle 16" Padding="16,8">
                    <Label Text="VOLUME"
                           FontFamily="OpenSansSemibold" FontSize="12" FontAttributes="Bold"
                           TextColor="{DynamicResource OnSecondary}" />
                </Border>
                <Border BackgroundColor="{DynamicResource SurfaceContainer}"
                        StrokeShape="RoundRectangle 16" Padding="16,8">
                    <Label Text="MASSIMALE"
                           FontFamily="OpenSansSemibold" FontSize="12" FontAttributes="Bold"
                           TextColor="{DynamicResource TextSecondary}" />
                </Border>
                <Border BackgroundColor="{DynamicResource SurfaceContainer}"
                        StrokeShape="RoundRectangle 16" Padding="16,8">
                    <Label Text="XP"
                           FontFamily="OpenSansSemibold" FontSize="12" FontAttributes="Bold"
                           TextColor="{DynamicResource TextSecondary}" />
                </Border>
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <!-- Compact Ranking List -->
        <ScrollView Grid.Row="1" Padding="20,0,20,100">
            <VerticalStackLayout Spacing="6">

                <!-- #1 Sofia -->
                <Border Style="{DynamicResource CardFrame}" BackgroundColor="{DynamicResource SurfaceContainerHigh}"
                        Padding="14,12">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border Grid.Column="0" BackgroundColor="{DynamicResource SurfaceContainer}"
                                StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36" Padding="0">
                            <Label Text="1" FontFamily="OpenSansSemibold" FontSize="16"
                                   TextColor="{DynamicResource LimeGreen}"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                            <Label Text="Sofia" FontFamily="OpenSansSemibold" FontSize="14" FontAttributes="Bold"
                                   TextColor="{DynamicResource OnSurface}" />
                            <Label Text="Prima in classifica" FontFamily="OpenSansRegular" FontSize="11"
                                   TextColor="{DynamicResource LimeGreen}" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="16.850 kg"
                               FontFamily="OpenSansSemibold" FontSize="16" FontAttributes="Bold"
                               TextColor="{DynamicResource Primary}" VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- #2 Marco (you) -->
                <Border Style="{DynamicResource CardFrame}" BackgroundColor="{DynamicResource PrimaryContainer}"
                        Stroke="{DynamicResource Primary}" StrokeThickness="1.5" Padding="14,12">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border Grid.Column="0" BackgroundColor="{DynamicResource Primary}"
                                StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36" Padding="0">
                            <Label Text="2" FontFamily="OpenSansSemibold" FontSize="16"
                                   TextColor="{DynamicResource OnPrimary}"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                            <Label Text="Tu · Marco" FontFamily="OpenSansSemibold" FontSize="14" FontAttributes="Bold"
                                   TextColor="{DynamicResource OnSurface}" />
                            <Label Text="2° posto" FontFamily="OpenSansRegular" FontSize="11"
                                   TextColor="{DynamicResource TextSecondary}" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="14.100 kg"
                               FontFamily="OpenSansSemibold" FontSize="16" FontAttributes="Bold"
                               TextColor="{DynamicResource OnSurface}" VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- #3 Luca -->
                <Border Style="{DynamicResource CardFrame}" BackgroundColor="{DynamicResource SurfaceContainerHigh}"
                        Padding="14,12">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border Grid.Column="0" BackgroundColor="{DynamicResource SurfaceContainer}"
                                StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36" Padding="0">
                            <Label Text="3" FontFamily="OpenSansSemibold" FontSize="16"
                                   TextColor="{DynamicResource TextSecondary}"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                            <Label Text="Luca" FontFamily="OpenSansSemibold" FontSize="14" FontAttributes="Bold"
                                   TextColor="{DynamicResource OnSurface}" />
                            <Label Text="3° posto" FontFamily="OpenSansRegular" FontSize="11"
                                   TextColor="{DynamicResource TextSecondary}" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="12.900 kg"
                               FontFamily="OpenSansSemibold" FontSize="16" FontAttributes="Bold"
                               TextColor="{DynamicResource Primary}" VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- #4 Andrea -->
                <Border Style="{DynamicResource CardFrame}" BackgroundColor="{DynamicResource SurfaceContainerHigh}"
                        Padding="14,12">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Border Grid.Column="0" BackgroundColor="{DynamicResource SurfaceContainer}"
                                StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36" Padding="0">
                            <Label Text="4" FontFamily="OpenSansSemibold" FontSize="16"
                                   TextColor="{DynamicResource TextSecondary}"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                            <Label Text="Andrea" FontFamily="OpenSansSemibold" FontSize="14" FontAttributes="Bold"
                                   TextColor="{DynamicResource OnSurface}" />
                            <Label Text="4° posto" FontFamily="OpenSansRegular" FontSize="11"
                                   TextColor="{DynamicResource TextSecondary}" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="12.550 kg"
                               FontFamily="OpenSansSemibold" FontSize="16" FontAttributes="Bold"
                               TextColor="{DynamicResource Primary}" VerticalOptions="Center" />
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
