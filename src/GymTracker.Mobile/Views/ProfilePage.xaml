<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:GymTracker.Mobile.ViewModels"
    x:Class="GymTracker.Mobile.Views.ProfilePage"
    x:DataType="vm:ProfileViewModel"
    Title="Profile"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*" BackgroundColor="{DynamicResource Surface}">

        <!-- Header — mockup style -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto"
              Padding="24,16" BackgroundColor="{DynamicResource Surface}">
            <Border Grid.Column="0" BackgroundColor="{DynamicResource SurfaceContainer}"
                    StrokeShape="RoundRectangle 999" WidthRequest="40" HeightRequest="40" Padding="0"
                    Stroke="{DynamicResource OutlineVariant}" StrokeThickness="0.5">
                <Label Text="←" FontSize="18" TextColor="{DynamicResource OnSurface}"
                       HorizontalOptions="Center" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </Border>
            <Label Grid.Column="1" Text="PROFILE"
                   FontFamily="OpenSansSemibold" FontSize="18" FontAttributes="Bold"
                   TextColor="{DynamicResource Primary}"
                   HorizontalOptions="Center" VerticalOptions="Center"
                   CharacterSpacing="-1" />
            <BoxView Grid.Column="2" WidthRequest="40" Color="Transparent" />
        </Grid>

        <ScrollView Grid.Row="1" Padding="24,8,24,100">
            <VerticalStackLayout Spacing="48">

                <!-- Profile Hero — centered avatar, name, tier -->
                <VerticalStackLayout Spacing="16" HorizontalOptions="Center">
                    <!-- Avatar 128x128 -->
                    <Border BackgroundColor="{DynamicResource SurfaceContainerHigh}"
                            StrokeShape="RoundRectangle 64"
                            Stroke="{DynamicResource Surface}" StrokeThickness="4"
                            WidthRequest="128" HeightRequest="128" Padding="0"
                            HorizontalOptions="Center">
                        <Label Text="{Binding AvatarInitials}" FontFamily="OpenSansSemibold" FontSize="40"
                               TextColor="{DynamicResource OnSurface}"
                               HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>

                    <!-- Name -->
                    <Label Text="{Binding Username}"
                           FontFamily="OpenSansSemibold" FontSize="28" FontAttributes="Bold"
                           TextColor="{DynamicResource OnSurface}"
                           HorizontalTextAlignment="Center" />

                    <!-- Tier with dot -->
                    <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Border BackgroundColor="{DynamicResource SecondaryContainer}"
                                StrokeShape="RoundRectangle 3"
                                WidthRequest="8" HeightRequest="8" Padding="0"
                                VerticalOptions="Center" />
                        <Label Text="{Binding Tier}"
                               FontFamily="OpenSansRegular" FontSize="18"
                               TextColor="{DynamicResource OnSurfaceVariant}" />
                    </HorizontalStackLayout>

                    <!-- Bio -->
                    <Label Text="{Binding Bio}"
                           FontFamily="OpenSansRegular" FontSize="14"
                           TextColor="{DynamicResource TextSecondary}"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <!-- Stats Grid 2x2 -->
                <Grid ColumnDefinitions="*,16,*" RowDefinitions="Auto,16,Auto">
                    <!-- Total Workouts -->
                    <Border Grid.Row="0" Grid.Column="0"
                            BackgroundColor="{DynamicResource SurfaceContainerLowest}"
                            StrokeShape="RoundRectangle 12"
                            Stroke="{DynamicResource OutlineVariant}" StrokeThickness="1"
                            Padding="20">
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center" VerticalOptions="Center">
                            <Label Text="{Binding TotalWorkouts}"
                                   FontFamily="OpenSansSemibold" FontSize="40" FontAttributes="Bold"
                                   TextColor="{DynamicResource Primary}"
                                   HorizontalTextAlignment="Center" />
                            <Label Text="TOTAL WORKOUTS"
                                   FontFamily="OpenSansSemibold" FontSize="11"
                                   TextColor="{DynamicResource OnSurfaceVariant}"
                                   CharacterSpacing="1"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Energy -->
                    <Border Grid.Row="0" Grid.Column="2"
                            BackgroundColor="{DynamicResource SurfaceContainerLowest}"
                            StrokeShape="RoundRectangle 12"
                            Stroke="{DynamicResource OutlineVariant}" StrokeThickness="1"
                            Padding="20">
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center" VerticalOptions="Center">
                            <Label Text="{Binding EnergyKcal}"
                                   FontFamily="OpenSansSemibold" FontSize="40" FontAttributes="Bold"
                                   TextColor="{DynamicResource SecondaryContainer}"
                                   HorizontalTextAlignment="Center" />
                            <Label Text="ENERGY (KCAL)"
                                   FontFamily="OpenSansSemibold" FontSize="11"
                                   TextColor="{DynamicResource OnSurfaceVariant}"
                                   CharacterSpacing="1"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Streak -->
                    <Border Grid.Row="2" Grid.Column="0"
                            BackgroundColor="{DynamicResource SurfaceContainerLowest}"
                            StrokeShape="RoundRectangle 12"
                            Stroke="{DynamicResource OutlineVariant}" StrokeThickness="1"
                            Padding="20">
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center" VerticalOptions="Center">
                            <Label Text="{Binding StreakDays}"
                                   FontFamily="OpenSansSemibold" FontSize="40" FontAttributes="Bold"
                                   TextColor="{DynamicResource Primary}"
                                   HorizontalTextAlignment="Center" />
                            <Label Text="{Binding StreakLabel}"
                                   FontFamily="OpenSansSemibold" FontSize="11"
                                   TextColor="{DynamicResource OnSurfaceVariant}"
                                   CharacterSpacing="1"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Recent Forges -->
                <VerticalStackLayout Spacing="16">
                    <Grid ColumnDefinitions="*,Auto" Padding="0,0,0,8">
                        <Label Grid.Column="0" Text="Recent Forges"
                               FontFamily="OpenSansSemibold" FontSize="20" FontAttributes="Bold"
                               TextColor="{DynamicResource OnSurface}" />
                        <Label Grid.Column="1" Text="View All"
                               FontFamily="OpenSansSemibold" FontSize="12"
                               TextColor="{DynamicResource Primary}" VerticalOptions="Center" />
                    </Grid>

                    <VerticalStackLayout Spacing="16"
                        BindableLayout.ItemsSource="{Binding RecentWorkouts}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:ProfileWorkout">
                                <Border BackgroundColor="{DynamicResource SurfaceContainerLowest}"
                                        StrokeShape="RoundRectangle 12"
                                        Stroke="{DynamicResource OutlineVariant}" StrokeThickness="1"
                                        Padding="20">
                                    <Grid ColumnDefinitions="4,16,*" RowDefinitions="Auto,Auto,Auto,Auto">
                                        <!-- Colored left border -->
                                        <Border Grid.Column="0" Grid.RowSpan="4"
                                                BackgroundColor="{Binding BorderColor}"
                                                StrokeShape="RoundRectangle 2"
                                                WidthRequest="4" VerticalOptions="Fill" />

                                        <!-- Title + Category -->
                                        <Grid Grid.Column="2" Grid.Row="0"
                                              ColumnDefinitions="*,Auto">
                                            <VerticalStackLayout>
                                                <Label Text="{Binding Title}"
                                                       FontFamily="OpenSansSemibold" FontSize="20" FontAttributes="Bold"
                                                       TextColor="{DynamicResource OnSurface}" />
                                                <Label Text="{Binding Date}"
                                                       FontFamily="OpenSansRegular" FontSize="16"
                                                       TextColor="{DynamicResource OnSurfaceVariant}" />
                                            </VerticalStackLayout>
                                            <Border Grid.Column="1"
                                                    BackgroundColor="{DynamicResource ErrorContainer}"
                                                    StrokeShape="RoundRectangle 12" Padding="12,6"
                                                    VerticalOptions="Start">
                                                <Label Text="{Binding Category}"
                                                       FontFamily="OpenSansSemibold" FontSize="11"
                                                       TextColor="{DynamicResource OnErrorContainer}"
                                                       CharacterSpacing="0.6" />
                                            </Border>
                                        </Grid>

                                        <!-- Stats chips -->
                                        <FlexLayout Grid.Column="2" Grid.Row="1"
                                                    Wrap="Wrap" Margin="0,12">
                                            <Border BackgroundColor="{DynamicResource SurfaceContainer}"
                                                    StrokeShape="RoundRectangle 8" Padding="12,8" Margin="0,0,8,8">
                                                <HorizontalStackLayout Spacing="6">
                                                    <Label Text="⏱" FontSize="14" VerticalOptions="Center" />
                                                    <Label Text="{Binding Duration}"
                                                           FontFamily="OpenSansSemibold" FontSize="14"
                                                           TextColor="{DynamicResource OnSurface}" />
                                                </HorizontalStackLayout>
                                            </Border>
                                            <Border BackgroundColor="{DynamicResource SurfaceContainer}"
                                                    StrokeShape="RoundRectangle 8" Padding="12,8" Margin="0,0,8,8">
                                                <HorizontalStackLayout Spacing="6">
                                                    <Label Text="♥" FontSize="14" VerticalOptions="Center" />
                                                    <Label Text="{Binding HeartRate}"
                                                           FontFamily="OpenSansSemibold" FontSize="14"
                                                           TextColor="{DynamicResource OnSurface}" />
                                                </HorizontalStackLayout>
                                            </Border>
                                            <Border BackgroundColor="{DynamicResource SurfaceContainer}"
                                                    StrokeShape="RoundRectangle 8" Padding="12,8" Margin="0,0,8,8">
                                                <HorizontalStackLayout Spacing="6">
                                                    <Label Text="🏋" FontSize="14" VerticalOptions="Center" />
                                                    <Label Text="{Binding Volume}"
                                                           FontFamily="OpenSansSemibold" FontSize="14"
                                                           TextColor="{DynamicResource OnSurface}" />
                                                </HorizontalStackLayout>
                                            </Border>
                                        </FlexLayout>

                                        <!-- Description -->
                                        <BoxView Grid.Column="2" Grid.Row="2"
                                                 HeightRequest="0.5"
                                                 Color="{DynamicResource OutlineVariant}"
                                                 Margin="0,8" />
                                        <VerticalStackLayout Grid.Column="2" Grid.Row="3" Spacing="6" Margin="0,8,0,0">
                                            <Label Text="PROTOCOL OUTLINE"
                                                   FontFamily="OpenSansSemibold" FontSize="11"
                                                   TextColor="{DynamicResource OnSurfaceVariant}"
                                                   CharacterSpacing="0.6" />
                                            <Label Text="{Binding Description}"
                                                   FontFamily="OpenSansRegular" FontSize="16"
                                                   TextColor="{DynamicResource OnSurface}"
                                                   LineBreakMode="WordWrap" />
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
