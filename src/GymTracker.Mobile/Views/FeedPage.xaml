<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:GymTracker.Mobile.ViewModels"
    x:Class="GymTracker.Mobile.Views.FeedPage"
    x:DataType="vm:FeedViewModel"
    Title="Feed"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,Auto,*" BackgroundColor="{DynamicResource Surface}">

        <!-- TopBar -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto"
              Padding="24,16" BackgroundColor="{DynamicResource Surface}">
            <Border Grid.Column="0" StrokeShape="RoundRectangle 999"
                    WidthRequest="40" HeightRequest="40" Padding="0"
                    BackgroundColor="{DynamicResource SurfaceContainerHigh}"
                    Stroke="{DynamicResource Primary}" StrokeThickness="2">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding OpenProfileCommand}" />
                </Border.GestureRecognizers>
                <Image Source="{Binding UserAvatarSource}" Aspect="AspectFill"
                       WidthRequest="40" HeightRequest="40"
                       IsVisible="{Binding HasUserAvatar}" />
                <Label Text="{Binding UserInitials}" FontFamily="OpenSansSemibold" FontSize="14"
                       TextColor="{DynamicResource Primary}" InputTransparent="True"
                       HorizontalOptions="Center" VerticalOptions="Center"
                       IsVisible="{Binding HasUserAvatar, Converter={StaticResource InverseBoolConverter}}" />
            </Border>
            <Label Grid.Column="1" Text="FORGE"
                   FontFamily="OpenSansSemibold" FontSize="20" FontAttributes="Bold"
                   TextColor="{DynamicResource Primary}"
                   HorizontalOptions="Center" VerticalOptions="Center"
                   CharacterSpacing="-1" />
            <Border Grid.Column="2" BackgroundColor="{DynamicResource SurfaceContainer}"
                    StrokeShape="RoundRectangle 999" WidthRequest="40" HeightRequest="40" Padding="0"
                    Stroke="{DynamicResource OutlineVariant}" StrokeThickness="0.5">
                <Label Text="⚙" FontSize="16" TextColor="{DynamicResource OnSurfaceVariant}"
                       HorizontalOptions="Center" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenSettingsCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </Border>
        </Grid>

        <!-- Search Bar -->
        <Border Grid.Row="1" Margin="24,0,24,8" BackgroundColor="{DynamicResource SurfaceContainer}"
                StrokeShape="RoundRectangle 12"
                Stroke="{DynamicResource OutlineVariant}" StrokeThickness="1" Padding="12,4">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Entry Grid.Column="0" Placeholder="Search athletes..."
                       Text="{Binding SearchQuery}" FontFamily="Inter" FontSize="14"
                       TextColor="{DynamicResource OnSurface}"
                       PlaceholderColor="{DynamicResource Outline}"
                       BackgroundColor="Transparent"
                       ReturnType="Search"
                       ReturnCommand="{Binding SearchUsersCommand}" />
                <Border Grid.Column="1" BackgroundColor="{DynamicResource Primary}"
                        StrokeShape="RoundRectangle 8" Padding="10,6">
                    <Label Text="SEARCH" FontFamily="Lexend" FontSize="10" FontAttributes="Bold"
                           TextColor="{DynamicResource OnPrimary}" VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SearchUsersCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </Border>
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollView Grid.Row="2" Padding="24,0,24,100">
            <VerticalStackLayout Spacing="16">

                <!-- Search Results -->
                <ActivityIndicator IsRunning="{Binding IsSearching}" IsVisible="{Binding IsSearching}"
                                   HorizontalOptions="Center" Color="{DynamicResource Primary}" />
                <Label Text="No users found" IsVisible="{Binding HasSearchResults, Converter={StaticResource InverseBoolConverter}}"
                       FontFamily="Inter" FontSize="13" TextColor="{DynamicResource TextSecondary}"
                       HorizontalOptions="Center" />

                <VerticalStackLayout Spacing="8" BindableLayout.ItemsSource="{Binding SearchResults}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:UserSearchResult">
                            <Border BackgroundColor="{DynamicResource SurfaceContainerLowest}"
                                    StrokeShape="RoundRectangle 12"
                                    Stroke="{DynamicResource OutlineVariant}" StrokeThickness="0.5"
                                    Padding="14">
                                    <Grid ColumnDefinitions="36,*,Auto" ColumnSpacing="10">
                                        <Border Grid.Column="0" BackgroundColor="{DynamicResource PrimaryContainer}"
                                                StrokeShape="RoundRectangle 999" WidthRequest="36" HeightRequest="36" Padding="0">
                                            <Grid>
                                                <Image Source="{Binding AvatarSource}" Aspect="AspectFill"
                                                       WidthRequest="36" HeightRequest="36"
                                                       IsVisible="{Binding HasAvatar}" />
                                                <Label Text="{Binding Initial}" FontFamily="SpaceGrotesk" FontSize="14" FontAttributes="Bold"
                                                       TextColor="{DynamicResource Primary}"
                                                       HorizontalOptions="Center" VerticalOptions="Center"
                                                       IsVisible="{Binding HasAvatar, Converter={StaticResource InverseBoolConverter}}" />
                                            </Grid>
                                        </Border>
                                    <Label Grid.Column="1" Text="{Binding Name}" FontFamily="SpaceGrotesk" FontSize="15"
                                           TextColor="{DynamicResource OnSurface}" VerticalOptions="Center" />
                                    <Border Grid.Column="2" BackgroundColor="{DynamicResource Primary}"
                                            StrokeShape="RoundRectangle 8" Padding="12,6" HeightRequest="32"
                                            IsVisible="{Binding IsFollowing, Converter={StaticResource InverseBoolConverter}}">
                                        <Label Text="{Binding FollowLabel}" FontFamily="Lexend" FontSize="10" FontAttributes="Bold"
                                               TextColor="{DynamicResource OnPrimary}" VerticalOptions="Center">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FeedViewModel}}, Path=FollowUserCommand}" CommandParameter="{Binding .}" />
                                            </Label.GestureRecognizers>
                                        </Label>
                                    </Border>
                                    <Label Grid.Column="2" Text="Following" FontFamily="Lexend" FontSize="10"
                                           TextColor="{DynamicResource TextSecondary}" VerticalOptions="Center"
                                           IsVisible="{Binding IsFollowing}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

                <!-- Feed label -->
                <Label Text="FOLLOWING" FontFamily="Lexend" FontSize="10" FontAttributes="Bold"
                       TextColor="{DynamicResource TextSecondary}" CharacterSpacing="1.5"
                       IsVisible="{Binding HasFeed}" Margin="0,8,0,0" />

                <!-- Loading -->
                <ActivityIndicator IsRunning="{Binding IsFeedBusy}" IsVisible="{Binding IsFeedBusy}"
                                   HorizontalOptions="Center" Color="{DynamicResource Primary}" />

                <!-- Feed Posts -->
                <VerticalStackLayout Spacing="20" BindableLayout.ItemsSource="{Binding Posts}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:FeedPost">
                            <Border BackgroundColor="{DynamicResource SurfaceContainerLowest}"
                                    StrokeShape="RoundRectangle 16"
                                    Stroke="{DynamicResource OutlineVariant}" StrokeThickness="0.5"
                                    Padding="20">
                                <VerticalStackLayout Spacing="12">
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                        <Border Grid.Column="0" StrokeShape="RoundRectangle 999"
                                                WidthRequest="40" HeightRequest="40" Padding="0"
                                                BackgroundColor="{DynamicResource PrimaryContainer}"
                                                Stroke="{DynamicResource Surface}" StrokeThickness="2">
                                            <Grid>
                                                <Image Source="{Binding AvatarSource}" Aspect="AspectFill"
                                                       WidthRequest="40" HeightRequest="40"
                                                       IsVisible="{Binding HasAvatar}" />
                                                <Label Text="{Binding Initial}"
                                                       FontFamily="SpaceGrotesk" FontSize="16"
                                                       TextColor="{DynamicResource Primary}"
                                                       HorizontalOptions="Center" VerticalOptions="Center"
                                                       IsVisible="{Binding HasAvatar, Converter={StaticResource InverseBoolConverter}}" />
                                            </Grid>
                                        </Border>
                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                                            <Label Text="{Binding UserName}"
                                                   FontFamily="SpaceGrotesk" FontSize="15" FontAttributes="Bold"
                                                   TextColor="{DynamicResource OnSurface}" />
                                            <Label Text="{Binding TimeAgo}"
                                                   FontFamily="Inter" FontSize="11"
                                                   TextColor="{DynamicResource TextSecondary}" />
                                        </VerticalStackLayout>
                                        <Border Grid.Column="2" BackgroundColor="{DynamicResource Primary}"
                                                Opacity="0.15" StrokeShape="RoundRectangle 999"
                                                Padding="10,4" VerticalOptions="Start">
                                            <Label Text="{Binding Duration}"
                                                   FontFamily="Lexend" FontSize="10" FontAttributes="Bold"
                                                   TextColor="{DynamicResource Primary}" />
                                        </Border>
                                    </Grid>

                                    <Label Text="{Binding Title}" FontFamily="SpaceGrotesk" FontSize="20" FontAttributes="Bold"
                                           TextColor="{DynamicResource Primary}" />

                                    <Label Text="{Binding ExercisesList}" FontFamily="Inter" FontSize="13"
                                           TextColor="{DynamicResource OnSurfaceVariant}" LineBreakMode="TailTruncation"
                                           MaxLines="2" />

                                    <Grid ColumnDefinitions="*,12,*">
                                        <Border Grid.Column="0" BackgroundColor="{DynamicResource SurfaceContainer}"
                                                StrokeShape="RoundRectangle 10" Padding="12">
                                            <VerticalStackLayout Spacing="2">
                                                <Label Text="VOLUME" FontFamily="Lexend" FontSize="9" FontAttributes="Bold"
                                                       TextColor="{DynamicResource TextSecondary}" CharacterSpacing="0.8" />
                                                <Label Text="{Binding Volume}" FontFamily="SpaceGrotesk" FontSize="18" FontAttributes="Bold"
                                                       TextColor="{DynamicResource OnSurface}" />
                                            </VerticalStackLayout>
                                        </Border>
                                    </Grid>

                                    <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="20" Padding="0,6,0,0">
                                        <Border Grid.Column="0" StrokeThickness="0" BackgroundColor="Transparent" Padding="0">
                                            <HorizontalStackLayout Spacing="6">
                                                <Label Text="{Binding HeartIcon}" FontSize="20"
                                                       VerticalOptions="Center">
                                                    <Label.Triggers>
                                                        <DataTrigger TargetType="Label" Binding="{Binding IsLiked}" Value="True">
                                                            <Setter Property="TextColor" Value="{DynamicResource LimeGreen}" />
                                                        </DataTrigger>
                                                        <DataTrigger TargetType="Label" Binding="{Binding IsLiked}" Value="False">
                                                            <Setter Property="TextColor" Value="{DynamicResource OnSurfaceVariant}" />
                                                        </DataTrigger>
                                                    </Label.Triggers>
                                                    <Label.GestureRecognizers>
                                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:FeedViewModel}}, Path=LikeWorkoutCommand}" CommandParameter="{Binding .}" />
                                                    </Label.GestureRecognizers>
                                                </Label>
                                                <Label Text="{Binding Likes}" FontFamily="Lexend" FontSize="14"
                                                       TextColor="{DynamicResource OnSurfaceVariant}" VerticalOptions="Center" />
                                            </HorizontalStackLayout>
                                        </Border>
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

                <!-- Empty State -->
                <Label Text="Follow athletes to see their workouts here"
                       FontFamily="Inter" FontSize="14" TextColor="{DynamicResource TextSecondary}"
                       HorizontalOptions="Center" Margin="0,40"
                       IsVisible="{Binding HasFeed, Converter={StaticResource InverseBoolConverter}}" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
