<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:GymTracker.Mobile.ViewModels"
    x:Class="GymTracker.Mobile.Views.StartSessionPage"
    x:DataType="vm:StartSessionViewModel"
    Title="FORGE_ELITE"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*" BackgroundColor="{DynamicResource Surface}">

        <!-- TopAppBar — mockup style -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto"
              Padding="24,16" BackgroundColor="{DynamicResource Surface}">
            <Border Grid.Column="0" BackgroundColor="{DynamicResource SurfaceContainer}"
                    StrokeShape="RoundRectangle 999" WidthRequest="40" HeightRequest="40" Padding="0"
                    Stroke="{DynamicResource OutlineVariant}" StrokeThickness="0.5">
                <Label Text="←" FontSize="18" TextColor="{DynamicResource OnSurface}"
                       HorizontalOptions="Center" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </Border>
            <Label Grid.Column="1" Text="FORGE_ELITE"
                   FontFamily="OpenSansSemibold" FontSize="18" FontAttributes="Bold"
                   TextColor="{DynamicResource Primary}"
                   HorizontalOptions="Center" VerticalOptions="Center"
                   CharacterSpacing="-1" />
            <Border Grid.Column="2" BackgroundColor="{DynamicResource SurfaceContainerHigh}"
                    StrokeShape="RoundRectangle 999" WidthRequest="40" HeightRequest="40" Padding="0"
                    Stroke="{DynamicResource OutlineVariant}" StrokeThickness="0.5">
                <Label Text="👤" FontSize="16" TextColor="{DynamicResource OnSurfaceVariant}"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>
        </Grid>

        <!-- Main Canvas -->
        <ScrollView Grid.Row="1" Padding="24,8,24,100">
            <VerticalStackLayout Spacing="48">

                <!-- Hero Header -->
                <Label Text="START_&#10;SESSION" FontFamily="OpenSansSemibold" FontSize="48"
                       FontAttributes="Bold" TextColor="{DynamicResource OnSurface}"
                       CharacterSpacing="-2" LineHeight="1" />

                <!-- Primary Actions -->
                <VerticalStackLayout Spacing="16">

                    <!-- Quick Start -->
                    <Border BackgroundColor="{DynamicResource SurfaceContainerLow}"
                            StrokeShape="RoundRectangle 12"
                            Stroke="{DynamicResource OutlineVariant}" StrokeThickness="1"
                            Padding="20">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding QuickStartCommand}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                            <Border Grid.Column="0" BackgroundColor="{DynamicResource SurfaceContainerHighest}"
                                    StrokeShape="RoundRectangle 999" WidthRequest="48" HeightRequest="48" Padding="0"
                                    Stroke="{DynamicResource OutlineVariant}" StrokeThickness="1">
                                <Label Text="▶" FontSize="22" TextColor="{DynamicResource OnSurfaceVariant}"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                                <Label Text="Quick Start"
                                       FontFamily="OpenSansSemibold" FontSize="20" FontAttributes="Bold"
                                       TextColor="{DynamicResource OnSurface}" />
                                <Label Text="Empty session tracking"
                                       FontFamily="OpenSansRegular" FontSize="14"
                                       TextColor="{DynamicResource OnSurfaceVariant}" />
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›" FontSize="24"
                                   TextColor="{DynamicResource OutlineVariant}"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Border>

                    <!-- Create New Plan -->
                    <Border BackgroundColor="{DynamicResource SurfaceContainerLowest}"
                            StrokeShape="RoundRectangle 12"
                            Stroke="{DynamicResource Primary}" StrokeThickness="2"
                            Padding="28" Margin="0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CreateNewPlanCommand}" />
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="16" HorizontalOptions="Center">
                            <Border BackgroundColor="{DynamicResource Primary}"
                                    Opacity="0.2"
                                    StrokeShape="RoundRectangle 999" WidthRequest="64" HeightRequest="64" Padding="0"
                                    Stroke="{DynamicResource Primary}" StrokeThickness="1"
                                    HorizontalOptions="Center">
                                <Label Text="+" FontSize="32" TextColor="{DynamicResource Primary}"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Label Text="CREATE_NEW_PLAN"
                                   FontFamily="OpenSansSemibold" FontSize="20" FontAttributes="Bold"
                                   TextColor="{DynamicResource Primary}"
                                   HorizontalTextAlignment="Center"
                                   CharacterSpacing="1" />
                            <Label Text="CUSTOM PROTOCOL"
                                   FontFamily="OpenSansSemibold" FontSize="10"
                                   TextColor="{DynamicResource Primary}"
                                   Opacity="0.7"
                                   HorizontalTextAlignment="Center"
                                   CharacterSpacing="2" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- Your Protocols -->
                <VerticalStackLayout Spacing="16">
                    <HorizontalStackLayout Spacing="8">
                        <Border BackgroundColor="{DynamicResource Primary}"
                                StrokeShape="RoundRectangle 3"
                                WidthRequest="8" HeightRequest="8" Padding="0"
                                VerticalOptions="Center" />
                        <Label Text="YOUR PROTOCOLS"
                               FontFamily="OpenSansSemibold" FontSize="11"
                               TextColor="{DynamicResource OnSurfaceVariant}"
                               CharacterSpacing="1.2"
                               VerticalTextAlignment="Center" />
                    </HorizontalStackLayout>

                    <VerticalStackLayout Spacing="16"
                        BindableLayout.ItemsSource="{Binding Protocols}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:ProtocolCard">
                                <Border BackgroundColor="{DynamicResource SurfaceContainerLowest}"
                                        StrokeShape="RoundRectangle 12"
                                        Stroke="{DynamicResource OutlineVariant}" StrokeThickness="1"
                                        Padding="20" MinimumHeightRequest="160">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:StartSessionViewModel}}, Path=StartProtocolCommand}" CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>
                                    <Grid RowDefinitions="*,Auto" RowSpacing="0">
                                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                                            <Label Grid.Column="0" Text="{Binding Name}"
                                                   FontFamily="OpenSansSemibold" FontSize="18" FontAttributes="Bold"
                                                   TextColor="{DynamicResource OnSurface}"
                                                   VerticalOptions="Start" />
                                            <Label Grid.Column="1" Text="✕" FontSize="16"
                                                   TextColor="{DynamicResource AlertRed}"
                                                   VerticalOptions="Start" Padding="8,0,0,0">
                                                <Label.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:StartSessionViewModel}}, Path=DeleteProtocolCommand}" CommandParameter="{Binding .}" />
                                                </Label.GestureRecognizers>
                                            </Label>
                                        </Grid>
                                        <HorizontalStackLayout Grid.Row="1" Spacing="16" VerticalOptions="End">
                                            <HorizontalStackLayout Spacing="4">
                                                <Label Text="⏱" FontSize="12"
                                                       TextColor="{DynamicResource OnSurfaceVariant}"
                                                       VerticalOptions="Center" />
                                                <Label Text="{Binding Duration}"
                                                       FontFamily="OpenSansSemibold" FontSize="11"
                                                       TextColor="{DynamicResource OnSurfaceVariant}"
                                                       CharacterSpacing="0.6"
                                                       VerticalOptions="Center" />
                                            </HorizontalStackLayout>
                                            <HorizontalStackLayout Spacing="4">
                                                <Label Text="🔥" FontSize="12"
                                                       TextColor="{DynamicResource LimeGreen}"
                                                       VerticalOptions="Center" />
                                                <Label Text="{Binding Intensity}"
                                                       FontFamily="OpenSansSemibold" FontSize="11"
                                                       TextColor="{DynamicResource LimeGreen}"
                                                       CharacterSpacing="0.6"
                                                       VerticalOptions="Center" />
                                            </HorizontalStackLayout>
                                        </HorizontalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
