<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:GymTracker.Mobile.ViewModels"
    x:Class="GymTracker.Mobile.Views.StatsPage"
    x:DataType="vm:StatsViewModel"
    Title="Stats"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*" BackgroundColor="{StaticResource Surface}">

        <!-- TopBar — exact mockup -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto"
              Padding="24,16" BackgroundColor="{StaticResource Surface}">
            <Border Grid.Column="0" StrokeShape="RoundRectangle 999"
                    WidthRequest="40" HeightRequest="40" Padding="0"
                    BackgroundColor="{StaticResource PrimaryContainer}">
                <Label Text="F" FontFamily="LexendBold" FontSize="18"
                       TextColor="{StaticResource OnPrimaryContainer}"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>
            <Label Grid.Column="1" Text="FORGE"
                   FontFamily="LexendBold" FontSize="32" FontAttributes="Bold"
                   TextColor="{StaticResource Primary}"
                   HorizontalOptions="Center" VerticalOptions="Center"
                   CharacterSpacing="-1" />
            <Border Grid.Column="2" BackgroundColor="{StaticResource SurfaceContainer}"
                    StrokeShape="RoundRectangle 999" WidthRequest="40" HeightRequest="40" Padding="0"
                    Stroke="{StaticResource OutlineVariant}" StrokeThickness="0.5">
                <Label Text="⚙" FontSize="16" TextColor="{StaticResource OnSurfaceVariant}"
                       HorizontalOptions="Center" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSettingsTapped" />
                    </Label.GestureRecognizers>
                </Label>
            </Border>
        </Grid>

        <!-- Content -->
        <ScrollView Grid.Row="1" Padding="24,16,24,100">
            <VerticalStackLayout Spacing="32">
                
                <!-- Header -->
                <VerticalStackLayout Spacing="8">
                    <Label Text="Analytics"
                           FontFamily="LexendBold" FontSize="32" FontAttributes="Bold"
                           TextColor="{StaticResource OnSurface}" />
                    <Label Text="Your performance overview"
                           FontFamily="InterRegular" FontSize="16"
                           TextColor="{StaticResource OnSurfaceVariant}" />
                </VerticalStackLayout>

                <!-- 2x2 Summary Tiles -->
                <Grid ColumnDefinitions="*,16,*" RowDefinitions="Auto,16,Auto">
                    
                    <!-- Total Hours -->
                    <Border Grid.Row="0" Grid.Column="0"
                            BackgroundColor="{StaticResource SurfaceContainerLowest}"
                            StrokeShape="RoundRectangle 12"
                            Stroke="{StaticResource OutlineVariant}" StrokeThickness="1"
                            Padding="20">
                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0" Text="TOTAL HOURS"
                                       FontFamily="InterBold" FontSize="12" FontAttributes="Bold"
                                       TextColor="{StaticResource OnSurfaceVariant}" CharacterSpacing="0.6" />
                                <Label Grid.Column="1" Text="◉" FontSize="14"
                                       TextColor="{StaticResource Primary}" />
                            </Grid>
                            <Label Text="{Binding TotalHours}"
                                   FontFamily="LexendBold" FontSize="48" FontAttributes="Bold"
                                   TextColor="{StaticResource OnSurface}"
                                   CharacterSpacing="-2" LineHeight="1" />
                            <HorizontalStackLayout Spacing="4">
                                <Label Text="▲" FontSize="12" TextColor="{StaticResource LimeGreen}" />
                                <Label Text="{Binding TotalHoursTrend}"
                                       FontFamily="InterBold" FontSize="12" FontAttributes="Bold"
                                       TextColor="{StaticResource LimeGreen}" CharacterSpacing="0.6" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Calories -->
                    <Border Grid.Row="0" Grid.Column="2"
                            BackgroundColor="{StaticResource SurfaceContainerLowest}"
                            StrokeShape="RoundRectangle 12"
                            Stroke="{StaticResource OutlineVariant}" StrokeThickness="1"
                            Padding="20">
                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0" Text="CALORIES"
                                       FontFamily="InterBold" FontSize="12" FontAttributes="Bold"
                                       TextColor="{StaticResource OnSurfaceVariant}" CharacterSpacing="0.6" />
                                <Label Grid.Column="1" Text="✦" FontSize="14"
                                       TextColor="{StaticResource Tertiary}" />
                            </Grid>
                            <Label Text="{Binding Calories}"
                                   FontFamily="LexendBold" FontSize="48" FontAttributes="Bold"
                                   TextColor="{StaticResource OnSurface}"
                                   CharacterSpacing="-2" LineHeight="1" />
                            <HorizontalStackLayout Spacing="4">
                                <Label Text="▲" FontSize="12" TextColor="{StaticResource LimeGreen}" />
                                <Label Text="{Binding CaloriesTrend}"
                                       FontFamily="InterBold" FontSize="12" FontAttributes="Bold"
                                       TextColor="{StaticResource LimeGreen}" CharacterSpacing="0.6" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Workouts -->
                    <Border Grid.Row="2" Grid.Column="0"
                            BackgroundColor="{StaticResource SurfaceContainerLowest}"
                            StrokeShape="RoundRectangle 12"
                            Stroke="{StaticResource OutlineVariant}" StrokeThickness="1"
                            Padding="20">
                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0" Text="WORKOUTS"
                                       FontFamily="InterBold" FontSize="12" FontAttributes="Bold"
                                       TextColor="{StaticResource OnSurfaceVariant}" CharacterSpacing="0.6" />
                                <Label Grid.Column="1" Text="◉" FontSize="14"
                                       TextColor="{StaticResource Primary}" />
                            </Grid>
                            <Label Text="{Binding Workouts}"
                                   FontFamily="LexendBold" FontSize="48" FontAttributes="Bold"
                                   TextColor="{StaticResource OnSurface}"
                                   CharacterSpacing="-2" LineHeight="1" />
                            <Label Text="{Binding WorkoutsTrend}"
                                   FontFamily="InterBold" FontSize="12" FontAttributes="Bold"
                                   TextColor="{StaticResource OnSurfaceVariant}" CharacterSpacing="0.6" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- New PRs -->
                    <Border Grid.Row="2" Grid.Column="2"
                            BackgroundColor="{StaticResource SurfaceContainerLowest}"
                            StrokeShape="RoundRectangle 12"
                            Stroke="{StaticResource OutlineVariant}" StrokeThickness="1"
                            Padding="20">
                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0" Text="NEW PRs"
                                       FontFamily="InterBold" FontSize="12" FontAttributes="Bold"
                                       TextColor="{StaticResource OnSurfaceVariant}" CharacterSpacing="0.6" />
                                <Label Grid.Column="1" Text="◆" FontSize="14"
                                       TextColor="{StaticResource LimeGreen}" />
                            </Grid>
                            <Label Text="{Binding NewPRs}"
                                   FontFamily="LexendBold" FontSize="48" FontAttributes="Bold"
                                   TextColor="{StaticResource OnSurface}"
                                   CharacterSpacing="-2" LineHeight="1" />
                            <HorizontalStackLayout Spacing="4">
                                <Label Text="▲" FontSize="12" TextColor="{StaticResource LimeGreen}" />
                                <Label Text="{Binding NewPRsTrend}"
                                       FontFamily="InterBold" FontSize="12" FontAttributes="Bold"
                                       TextColor="{StaticResource LimeGreen}" CharacterSpacing="0.6" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                </Grid>

                <!-- Muscle Mass Gain -->
                <Border BackgroundColor="{StaticResource SurfaceContainerLowest}"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource OutlineVariant}" StrokeThickness="1"
                        Padding="24">
                    <VerticalStackLayout Spacing="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label Text="Muscle Mass Gain"
                                       FontFamily="LexendBold" FontSize="24" FontAttributes="Bold"
                                       TextColor="{StaticResource OnSurface}" />
                                <Label Text="Estimated lean mass trend"
                                       FontFamily="InterRegular" FontSize="16"
                                       TextColor="{StaticResource OnSurfaceVariant}" />
                            </VerticalStackLayout>
                            <Border Grid.Column="1" BackgroundColor="{StaticResource LimeGreen}"
                                    Opacity="0.20" StrokeShape="RoundRectangle 999"
                                    Padding="12,4" VerticalOptions="Start">
                                <HorizontalStackLayout Spacing="4">
                                    <Label Text="▲" FontSize="12" TextColor="{StaticResource LimeGreen}" />
                                    <Label Text="{Binding MuscleGain}"
                                           FontFamily="InterBold" FontSize="12" FontAttributes="Bold"
                                           TextColor="{StaticResource LimeGreen}" />
                                </HorizontalStackLayout>
                            </Border>
                        </Grid>
                        <!-- Chart area -->
                        <Border BackgroundColor="{StaticResource SurfaceVariant}"
                                Opacity="0.3" StrokeShape="RoundRectangle 8"
                                HeightRequest="192" Padding="12">
                            <BoxView Color="{StaticResource Primary}" Opacity="0.6"
                                     CornerRadius="4" VerticalOptions="End"
                                     HeightRequest="80" />
                        </Border>
                        <Grid ColumnDefinitions="*,*,*,*,*,*">
                            <Label Grid.Column="0" Text="Jan" FontFamily="InterRegular" FontSize="11"
                                   TextColor="{StaticResource OnSurfaceVariant}" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="Feb" FontFamily="InterRegular" FontSize="11"
                                   TextColor="{StaticResource OnSurfaceVariant}" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="Mar" FontFamily="InterRegular" FontSize="11"
                                   TextColor="{StaticResource OnSurfaceVariant}" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="3" Text="Apr" FontFamily="InterRegular" FontSize="11"
                                   TextColor="{StaticResource OnSurfaceVariant}" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="4" Text="May" FontFamily="InterRegular" FontSize="11"
                                   TextColor="{StaticResource OnSurfaceVariant}" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="5" Text="Jun" FontFamily="InterRegular" FontSize="11"
                                   TextColor="{StaticResource OnSurfaceVariant}" HorizontalTextAlignment="Center" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Weekly Volume -->
                <Border BackgroundColor="{StaticResource SurfaceContainerLowest}"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource OutlineVariant}" StrokeThickness="1"
                        Padding="24">
                    <VerticalStackLayout Spacing="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" Text="Weekly Volume"
                                   FontFamily="LexendBold" FontSize="24" FontAttributes="Bold"
                                   TextColor="{StaticResource OnSurface}" />
                            <Label Grid.Column="1" Text="Tonnes"
                                   FontFamily="InterBold" FontSize="12" FontAttributes="Bold"
                                   TextColor="{StaticResource OnSurfaceVariant}" CharacterSpacing="0.6" />
                        </Grid>
                        <!-- Bar chart -->
                        <Grid HeightRequest="200" ColumnDefinitions="*,*,*,*,*,*,*" ColumnSpacing="4"
                              VerticalOptions="End">
                            <BoxView Grid.Column="0" Color="{StaticResource Primary}" CornerRadius="3,3,0,0"
                                     VerticalOptions="End" HeightRequest="{Binding BarHeight0}" Opacity="0.3" />
                            <BoxView Grid.Column="1" Color="{StaticResource Primary}" CornerRadius="3,3,0,0"
                                     VerticalOptions="End" HeightRequest="{Binding BarHeight1}" Opacity="0.4" />
                            <BoxView Grid.Column="2" Color="{StaticResource Primary}" CornerRadius="3,3,0,0"
                                     VerticalOptions="End" HeightRequest="{Binding BarHeight2}" Opacity="0.6" />
                            <BoxView Grid.Column="3" Color="{StaticResource Primary}" CornerRadius="3,3,0,0"
                                     VerticalOptions="End" HeightRequest="{Binding BarHeight3}" Opacity="0.8" />
                            <BoxView Grid.Column="4" Color="{StaticResource Primary}" CornerRadius="3,3,0,0"
                                     VerticalOptions="End" HeightRequest="{Binding BarHeight4}" />
                            <BoxView Grid.Column="5" Color="{StaticResource Primary}" CornerRadius="3,3,0,0"
                                     VerticalOptions="End" HeightRequest="{Binding BarHeight5}" Opacity="0.5" />
                            <BoxView Grid.Column="6" Color="{StaticResource Primary}" CornerRadius="3,3,0,0"
                                     VerticalOptions="End" HeightRequest="{Binding BarHeight6}" Opacity="0.3" />
                        </Grid>
                        <Grid ColumnDefinitions="*,*,*,*,*,*,*">
                            <Label Grid.Column="0" Text="M" FontFamily="InterRegular" FontSize="11"
                                   TextColor="{StaticResource OnSurfaceVariant}" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="T" FontFamily="InterRegular" FontSize="11"
                                   TextColor="{StaticResource OnSurfaceVariant}" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="W" FontFamily="InterRegular" FontSize="11"
                                   TextColor="{StaticResource OnSurfaceVariant}" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="3" Text="T" FontFamily="InterRegular" FontSize="11"
                                   TextColor="{StaticResource OnSurfaceVariant}" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="4" Text="F" FontFamily="InterRegular" FontSize="11"
                                   TextColor="{StaticResource OnSurfaceVariant}" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="5" Text="S" FontFamily="InterRegular" FontSize="11"
                                   TextColor="{StaticResource OnSurfaceVariant}" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="6" Text="S" FontFamily="InterRegular" FontSize="11"
                                   TextColor="{StaticResource OnSurfaceVariant}" HorizontalTextAlignment="Center" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Top Lifts -->
                <Border BackgroundColor="{StaticResource SurfaceContainerLowest}"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{StaticResource OutlineVariant}" StrokeThickness="1"
                        Padding="24">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Top Lifts"
                               FontFamily="LexendBold" FontSize="24" FontAttributes="Bold"
                               TextColor="{StaticResource OnSurface}" />
                        <VerticalStackLayout Spacing="0"
                            BindableLayout.ItemsSource="{Binding TopLifts}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="vm:LiftEntry">
                                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="0,12"
                                          ColumnSpacing="12">
                                        <Border Grid.Column="0" BackgroundColor="{StaticResource Primary}"
                                                Opacity="0.10" StrokeShape="RoundRectangle 999"
                                                WidthRequest="40" HeightRequest="40" Padding="0">
                                            <Label Text="◉" FontSize="14" TextColor="{StaticResource Primary}"
                                                   HorizontalOptions="Center" VerticalOptions="Center" />
                                        </Border>
                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                                            <Label Text="{Binding Name}"
                                                   FontFamily="InterBold" FontSize="18"
                                                   TextColor="{StaticResource OnSurface}" />
                                            <Label Text="{Binding Label}"
                                                   FontFamily="InterBold" FontSize="12" FontAttributes="Bold"
                                                   TextColor="{StaticResource OnSurfaceVariant}" CharacterSpacing="0.6" />
                                        </VerticalStackLayout>
                                        <Label Grid.Column="2" Text="{Binding Weight}"
                                               FontFamily="LexendBold" FontSize="24" FontAttributes="Bold"
                                               TextColor="{StaticResource OnSurface}"
                                               VerticalOptions="Center" />
                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
