<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:GymTracker.Mobile.ViewModels"
    x:Class="GymTracker.Mobile.Views.StatsPage"
    x:DataType="vm:StatsViewModel"
    Title="Stats"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*" BackgroundColor="{DynamicResource Surface}">

        <!-- TopBar — statistiche avanzate nero opaco mockup -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto"
              Padding="24,16" BackgroundColor="{DynamicResource Surface}">
            <!-- Left: Profile Elite avatar -->
            <Border Grid.Column="0" StrokeShape="RoundRectangle 999"
                    WidthRequest="40" HeightRequest="40" Padding="0"
                    BackgroundColor="{DynamicResource SurfaceContainerHigh}"
                    Stroke="{DynamicResource Primary}" StrokeThickness="2">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding OpenProfileCommand}" />
                </Border.GestureRecognizers>
                <Label Text="EL" FontFamily="OpenSansSemibold" FontSize="14"
                       TextColor="{DynamicResource Primary}"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>
            <!-- Center: FORGE title -->
            <Label Grid.Column="1" Text="FORGE"
                   FontFamily="OpenSansSemibold" FontSize="20" FontAttributes="Bold"
                   TextColor="{DynamicResource Primary}"
                   HorizontalOptions="Center" VerticalOptions="Center"
                   CharacterSpacing="-1" />
            <!-- Right: Friend Requests -->
            <Border Grid.Column="2" BackgroundColor="{DynamicResource SurfaceContainer}"
                    StrokeShape="RoundRectangle 999" WidthRequest="40" HeightRequest="40" Padding="0"
                    Stroke="{DynamicResource OutlineVariant}" StrokeThickness="0.5">
                <Label Text="♥" FontSize="20" TextColor="{DynamicResource Primary}"
                       HorizontalOptions="Center" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenFriendRequestsCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </Border>
        </Grid>

        <!-- Content -->
        <ScrollView Grid.Row="1" Padding="24,16,24,100">
            <VerticalStackLayout Spacing="32">

                <!-- Header -->
                <VerticalStackLayout Spacing="8">
                    <Label Text="Analytics"
                           FontFamily="OpenSansSemibold" FontSize="32" FontAttributes="Bold"
                           TextColor="{DynamicResource OnSurface}" />
                    <Label Text="Your performance overview"
                           FontFamily="OpenSansRegular" FontSize="16"
                           TextColor="{DynamicResource OnSurfaceVariant}" />
                </VerticalStackLayout>

                <!-- Empty / Error state -->
                <VerticalStackLayout IsVisible="{Binding HasStatsError}"
                                     Spacing="16" HorizontalOptions="Center" Padding="0,40">
                    <Label Text="📊" FontSize="48" HorizontalTextAlignment="Center" />
                    <Label Text="{Binding StatsError}"
                           FontFamily="Inter" FontSize="16"
                           TextColor="{DynamicResource OnSurfaceVariant}"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <!-- Stats content (hidden when empty) -->
                <VerticalStackLayout Spacing="32"
                    IsVisible="{Binding IsEmptyState, Converter={StaticResource InverseBoolConverter}}">

                <!-- Time Filters -->
                <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                    <HorizontalStackLayout Spacing="8">
                        <Button Text="WEEK" Command="{Binding SetFilterCommand}" CommandParameter="week"
                                FontFamily="Lexend" FontSize="10" FontAttributes="Bold"
                                BackgroundColor="{DynamicResource SurfaceContainer}" TextColor="{DynamicResource OnSurfaceVariant}"
                                HeightRequest="32" CornerRadius="16" Padding="16,0">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding SelectedFilter}" Value="week">
                                    <Setter Property="BackgroundColor" Value="{DynamicResource Primary}" />
                                    <Setter Property="TextColor" Value="{DynamicResource OnPrimary}" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                        <Button Text="MONTH" Command="{Binding SetFilterCommand}" CommandParameter="month"
                                FontFamily="Lexend" FontSize="10" FontAttributes="Bold"
                                BackgroundColor="{DynamicResource SurfaceContainer}" TextColor="{DynamicResource OnSurfaceVariant}"
                                HeightRequest="32" CornerRadius="16" Padding="16,0">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding SelectedFilter}" Value="month">
                                    <Setter Property="BackgroundColor" Value="{DynamicResource Primary}" />
                                    <Setter Property="TextColor" Value="{DynamicResource OnPrimary}" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                        <Button Text="3 MONTHS" Command="{Binding SetFilterCommand}" CommandParameter="3months"
                                FontFamily="Lexend" FontSize="10" FontAttributes="Bold"
                                BackgroundColor="{DynamicResource SurfaceContainer}" TextColor="{DynamicResource OnSurfaceVariant}"
                                HeightRequest="32" CornerRadius="16" Padding="16,0">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding SelectedFilter}" Value="3months">
                                    <Setter Property="BackgroundColor" Value="{DynamicResource Primary}" />
                                    <Setter Property="TextColor" Value="{DynamicResource OnPrimary}" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                        <Button Text="1 YEAR" Command="{Binding SetFilterCommand}" CommandParameter="year"
                                FontFamily="Lexend" FontSize="10" FontAttributes="Bold"
                                BackgroundColor="{DynamicResource SurfaceContainer}" TextColor="{DynamicResource OnSurfaceVariant}"
                                HeightRequest="32" CornerRadius="16" Padding="16,0">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding SelectedFilter}" Value="year">
                                    <Setter Property="BackgroundColor" Value="{DynamicResource Primary}" />
                                    <Setter Property="TextColor" Value="{DynamicResource OnPrimary}" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                        <Button Text="ALL" Command="{Binding SetFilterCommand}" CommandParameter="all"
                                FontFamily="Lexend" FontSize="10" FontAttributes="Bold"
                                BackgroundColor="{DynamicResource SurfaceContainer}" TextColor="{DynamicResource OnSurfaceVariant}"
                                HeightRequest="32" CornerRadius="16" Padding="16,0">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding SelectedFilter}" Value="all">
                                    <Setter Property="BackgroundColor" Value="{DynamicResource Primary}" />
                                    <Setter Property="TextColor" Value="{DynamicResource OnPrimary}" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                    </HorizontalStackLayout>
                </ScrollView>

                <!-- 3 Summary Tiles -->
                <Grid ColumnDefinitions="*,12,*" RowDefinitions="Auto,12,Auto">
                    <Border Grid.Row="0" Grid.Column="0"
                            BackgroundColor="{DynamicResource SurfaceContainerLowest}"
                            StrokeShape="RoundRectangle 12"
                            Stroke="{DynamicResource OutlineVariant}" StrokeThickness="1" Padding="20">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="GYM TIME" FontFamily="Lexend" FontSize="10" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextSecondary}" CharacterSpacing="0.8" />
                            <Label Text="{Binding TotalHours}" FontFamily="SpaceGrotesk" FontSize="36" FontAttributes="Bold"
                                   TextColor="{DynamicResource OnSurface}" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Row="0" Grid.Column="2"
                            BackgroundColor="{DynamicResource SurfaceContainerLowest}"
                            StrokeShape="RoundRectangle 12"
                            Stroke="{DynamicResource OutlineVariant}" StrokeThickness="1" Padding="20">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="VOLUME" FontFamily="Lexend" FontSize="10" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextSecondary}" CharacterSpacing="0.8" />
                            <Label Text="{Binding TotalVolume}" FontFamily="SpaceGrotesk" FontSize="36" FontAttributes="Bold"
                                   TextColor="{DynamicResource LimeGreen}" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Row="2" Grid.Column="0"
                            BackgroundColor="{DynamicResource SurfaceContainerLowest}"
                            StrokeShape="RoundRectangle 12"
                            Stroke="{DynamicResource OutlineVariant}" StrokeThickness="1" Padding="20">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="WORKOUTS" FontFamily="Lexend" FontSize="10" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextSecondary}" CharacterSpacing="0.8" />
                            <Label Text="{Binding Workouts}" FontFamily="SpaceGrotesk" FontSize="36" FontAttributes="Bold"
                                   TextColor="{DynamicResource Primary}" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Volume Over Time Chart -->
                <Border BackgroundColor="{DynamicResource SurfaceContainerLowest}"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{DynamicResource OutlineVariant}" StrokeThickness="1" Padding="20">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Volume Over Time" FontFamily="SpaceGrotesk" FontSize="18" FontAttributes="Bold"
                               TextColor="{DynamicResource OnSurface}" />
                        <Grid HeightRequest="160" ColumnSpacing="2" VerticalOptions="End"
                              BindableLayout.ItemsSource="{Binding BarHeights}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="vm:BarEntry">
                                    <BoxView Color="{DynamicResource Primary}" CornerRadius="3,3,0,0"
                                             VerticalOptions="End"
                                             HeightRequest="{Binding Height}" Opacity="0.8" />
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </Grid>
                        <Grid BindableLayout.ItemsSource="{Binding BarLabels}" ColumnSpacing="2">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="vm:LabelEntry">
                                    <Label Text="{Binding Text}" FontFamily="Lexend" FontSize="9"
                                           TextColor="{DynamicResource TextSecondary}"
                                           HorizontalTextAlignment="Center" VerticalOptions="Center">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsMonthLabel}" Value="True">
                                                <Setter Property="FontAttributes" Value="Bold" />
                                                <Setter Property="FontSize" Value="8" />
                                                <Setter Property="TextColor" Value="{DynamicResource Primary}" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Calendar -->
                <Border BackgroundColor="{DynamicResource SurfaceContainerLowest}"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{DynamicResource OutlineVariant}" StrokeThickness="1" Padding="20">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="{Binding CalendarMonth}" FontFamily="SpaceGrotesk" FontSize="18" FontAttributes="Bold"
                               TextColor="{DynamicResource OnSurface}" />
                        <Grid ColumnDefinitions="*,*,*,*,*,*,*">
                            <Label Text="M" FontFamily="Lexend" FontSize="10" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextSecondary}" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="T" FontFamily="Lexend" FontSize="10" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextSecondary}" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="W" FontFamily="Lexend" FontSize="10" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextSecondary}" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="3" Text="T" FontFamily="Lexend" FontSize="10" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextSecondary}" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="4" Text="F" FontFamily="Lexend" FontSize="10" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextSecondary}" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="5" Text="S" FontFamily="Lexend" FontSize="10" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextSecondary}" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="6" Text="S" FontFamily="Lexend" FontSize="10" FontAttributes="Bold"
                                   TextColor="{DynamicResource TextSecondary}" HorizontalTextAlignment="Center" />
                        </Grid>
                        <CollectionView ItemsSource="{Binding CalendarDays}" ItemsLayout="VerticalGrid, 7">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:CalendarDay">
                                    <VerticalStackLayout HeightRequest="42" HorizontalOptions="Center" VerticalOptions="Center" Spacing="2">
                                        <Label Text="{Binding Day}" FontFamily="Lexend" FontSize="10"
                                               HorizontalOptions="Center" VerticalOptions="End"
                                               TextColor="{DynamicResource OnSurfaceVariant}">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsToday}" Value="True">
                                                    <Setter Property="FontAttributes" Value="Bold" />
                                                    <Setter Property="TextColor" Value="{DynamicResource LimeGreen}" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                        <Border WidthRequest="6" HeightRequest="6"
                                                StrokeShape="RoundRectangle 3"
                                                BackgroundColor="Transparent"
                                                HorizontalOptions="Center">
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border" Binding="{Binding HasWorkout}" Value="True">
                                                    <Setter Property="BackgroundColor" Value="{DynamicResource Primary}" />
                                                </DataTrigger>
                                            </Border.Triggers>
                                        </Border>
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <!-- Top Lifts -->
                <Border BackgroundColor="{DynamicResource SurfaceContainerLowest}"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{DynamicResource OutlineVariant}" StrokeThickness="1" Padding="20">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Top Lifts" FontFamily="SpaceGrotesk" FontSize="18" FontAttributes="Bold"
                               TextColor="{DynamicResource OnSurface}" />
                        <VerticalStackLayout Spacing="0"
                            BindableLayout.ItemsSource="{Binding TopLifts}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="vm:LiftEntry">
                                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="0,12" ColumnSpacing="12">
                                        <Border Grid.Column="0" BackgroundColor="{DynamicResource Primary}"
                                                Opacity="0.10" StrokeShape="RoundRectangle 999"
                                                WidthRequest="40" HeightRequest="40" Padding="0">
                                            <Label Text="◉" FontSize="14" TextColor="{DynamicResource Primary}"
                                                   HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>

                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                                            <Label Text="{Binding Name}" FontFamily="SpaceGrotesk" FontSize="18"
                                                   TextColor="{DynamicResource OnSurface}" />
                                            <Label Text="{Binding Label}" FontFamily="Lexend" FontSize="10" FontAttributes="Bold"
                                                   TextColor="{DynamicResource TextSecondary}" CharacterSpacing="0.6" />
                                        </VerticalStackLayout>
                                        <Label Grid.Column="2" Text="{Binding Weight}"
                                               FontFamily="SpaceGrotesk" FontSize="24" FontAttributes="Bold"
                                               TextColor="{DynamicResource OnSurface}" VerticalOptions="Center" />
                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
