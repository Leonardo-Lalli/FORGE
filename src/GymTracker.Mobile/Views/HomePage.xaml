<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:GymTracker.Mobile.ViewModels"
    x:Class="GymTracker.Mobile.Views.HomePage"
    x:DataType="vm:HomeViewModel"
    Title="FORGE"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*" BackgroundColor="{DynamicResource Surface}">

        <!-- TopBar — profilo elite nero opaco mockup -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto"
              Padding="24,16" BackgroundColor="{DynamicResource Surface}">
            <!-- Left: Profile Elite avatar -->
            <Border Grid.Column="0" BackgroundColor="{DynamicResource SurfaceContainerHigh}"
                    StrokeShape="RoundRectangle 999" WidthRequest="40" HeightRequest="40" Padding="0"
                    Stroke="{DynamicResource Primary}" StrokeThickness="2">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding OpenProfileCommand}" />
                </Border.GestureRecognizers>
                <Image Source="{Binding UserAvatarSource}" Aspect="AspectFill"
                       WidthRequest="40" HeightRequest="40"
                       IsVisible="{Binding HasUserAvatar}" />
                <Label Text="{Binding UserInitials}" FontFamily="OpenSansSemibold" FontSize="14"
                       TextColor="{DynamicResource Primary}" InputTransparent="True"
                       HorizontalOptions="Center" VerticalOptions="Center"
                       IsVisible="{Binding HasUserAvatar, Converter={StaticResource InverseBoolConverter}}" />
            </Border>
            <!-- Center: FORGE title -->
            <Label Grid.Column="1" Text="FORGE"
                   FontFamily="OpenSansSemibold" FontSize="18" FontAttributes="Bold"
                   TextColor="{DynamicResource Primary}"
                   HorizontalOptions="Center" VerticalOptions="Center"
                   CharacterSpacing="-1" />
            <!-- Right: Settings -->
            <Border Grid.Column="2" BackgroundColor="{DynamicResource SurfaceContainer}"
                    StrokeShape="RoundRectangle 999" WidthRequest="40" HeightRequest="40" Padding="0"
                    Stroke="{DynamicResource OutlineVariant}" StrokeThickness="0.5">
                <Label Text="⚙" FontSize="16" TextColor="{DynamicResource OnSurfaceVariant}"
                       HorizontalOptions="Center" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenSettingsCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </Border>
        </Grid>

        <!-- Main Scroll -->
        <ScrollView Grid.Row="1" Padding="24,0,24,100">
            <VerticalStackLayout Spacing="48">

                <!-- ===== Squad Activity ===== -->
                <VerticalStackLayout Spacing="16">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="Squad Activity"
                               FontFamily="OpenSansSemibold" FontSize="24" FontAttributes="Bold"
                               TextColor="{DynamicResource OnSurface}" />
                        <Label Grid.Column="1" Text="Feed →" FontFamily="Lexend" FontSize="12"
                               TextColor="{DynamicResource Primary}" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenFeedCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>
                    <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                        <HorizontalStackLayout Spacing="16"
                            BindableLayout.ItemsSource="{Binding Squad}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="vm:SquadMember">
                                    <VerticalStackLayout Spacing="8" WidthRequest="72"
                                        IsVisible="{Binding HasWorkout}">
                                        <Border StrokeShape="RoundRectangle 999"
                                                Stroke="{DynamicResource ElectricBlue}"
                                                StrokeThickness="2" Padding="2"
                                                WidthRequest="64" HeightRequest="64"
                                                BackgroundColor="{DynamicResource PrimaryContainer}">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HomeViewModel}}, Path=OpenFeedCommand}" />
                                            </Border.GestureRecognizers>
                                            <Grid>
                                                <Image Source="{Binding AvatarSource}" Aspect="AspectFill"
                                                       WidthRequest="60" HeightRequest="60"
                                                       IsVisible="{Binding HasAvatar}" />
                                                <Label Text="{Binding Initial}"
                                                       FontFamily="OpenSansSemibold" FontSize="22"
                                                       TextColor="{DynamicResource OnSurface}"
                                                       HorizontalOptions="Center" VerticalOptions="Center"
                                                       IsVisible="{Binding HasAvatar, Converter={StaticResource InverseBoolConverter}}" />
                                            </Grid>
                                        </Border>
                                        <Label Text="{Binding Name}"
                                               FontFamily="OpenSansRegular" FontSize="11"
                                               TextColor="{DynamicResource OnSurfaceVariant}"
                                               HorizontalTextAlignment="Center"
                                               LineBreakMode="TailTruncation" />
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </HorizontalStackLayout>
                    </ScrollView>
                </VerticalStackLayout>

                <!-- ===== Current Streak Hero Card ===== -->
                <Border BackgroundColor="{DynamicResource SurfaceContainerLowest}"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{DynamicResource OutlineVariant}" StrokeThickness="1"
                        Padding="24">
                    <VerticalStackLayout Spacing="16" HorizontalOptions="Center">
                        <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                            <Border BackgroundColor="{DynamicResource Primary}"
                                    Opacity="0.10" StrokeShape="RoundRectangle 999"
                                    WidthRequest="32" HeightRequest="32" Padding="0"
                                    Stroke="{DynamicResource Primary}" StrokeThickness="1">
                                <Label Text="✦" FontSize="14" TextColor="{DynamicResource Primary}"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Label Text="CURRENT STREAK"
                                   FontFamily="OpenSansSemibold" FontSize="12" FontAttributes="Bold"
                                   TextColor="{DynamicResource OnSurfaceVariant}"
                                   CharacterSpacing="2.4" VerticalOptions="Center" />
                        </HorizontalStackLayout>

                        <Label Text="{Binding StreakCount}"
                               FontFamily="OpenSansSemibold" FontSize="72" FontAttributes="Bold"
                               TextColor="{DynamicResource OnSurface}"
                               HorizontalTextAlignment="Center"
                               CharacterSpacing="-3" LineHeight="1" />

                        <Label Text="WEEKS"
                               FontFamily="OpenSansSemibold" FontSize="32" FontAttributes="Bold"
                               TextColor="{DynamicResource Primary}"
                               HorizontalTextAlignment="Center"
                               CharacterSpacing="2" Margin="0,-8,0,0" />

                        <Label Text="You are crushing it. Keep the momentum going for another week."
                               FontFamily="OpenSansRegular" FontSize="18"
                               TextColor="{DynamicResource OnSurfaceVariant}"
                               HorizontalTextAlignment="Center"
                               MaximumWidthRequest="320" />
                    </VerticalStackLayout>
                </Border>

                <!-- ===== Next Workout ===== -->
                <Border BackgroundColor="{DynamicResource SurfaceContainerLowest}"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{DynamicResource OutlineVariant}" StrokeThickness="1"
                        Padding="24" HeightRequest="128">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenNextWorkoutCommand}" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="0" VerticalOptions="End">
                        <HorizontalStackLayout>
                            <Label Text="◉" FontSize="16" TextColor="{DynamicResource Primary}"
                                   VerticalOptions="Center" Margin="0,0,8,0" />
                            <Label Text="Today" FontFamily="OpenSansRegular" FontSize="11"
                                   TextColor="{DynamicResource OnSurfaceVariant}"
                                   HorizontalOptions="End" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <Label Text="{Binding NextWorkout}" FontFamily="OpenSansSemibold" FontSize="24"
                               FontAttributes="Bold" TextColor="{DynamicResource OnSurface}"
                               Margin="0,4,0,0" />
                        <Label Text="{Binding WorkoutDuration}" FontFamily="OpenSansRegular" FontSize="11"
                               TextColor="{DynamicResource Primary}" Margin="0,4,0,0" />
                    </VerticalStackLayout>
                </Border>

                <!-- ===== Start Workout Button ===== -->
                <Button Text="▶  START WORKOUT"
                        BackgroundColor="{DynamicResource ElectricBlue}"
                        TextColor="{DynamicResource OnPrimary}"
                        FontFamily="OpenSansSemibold" FontSize="16"
                        FontAttributes="Bold"
                        HeightRequest="56" CornerRadius="8"
                        Command="{Binding StartWorkoutCommand}" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
