<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:GymTracker.Mobile.ViewModels"
    x:Class="GymTracker.Mobile.Views.NotificationsPage"
    x:DataType="vm:NotificationsViewModel"
    Title="Notifiche"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*" BackgroundColor="{DynamicResource Surface}">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Padding="20,16" ColumnSpacing="12">
            <Border BackgroundColor="{DynamicResource SurfaceContainer}"
                    StrokeShape="RoundRectangle 12" Padding="8" HeightRequest="40" WidthRequest="40">
                <Label Text="←" FontSize="18" TextColor="{DynamicResource OnSurface}"
                       HorizontalOptions="Center" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped" />
                    </Label.GestureRecognizers>
                </Label>
            </Border>
            <Label Grid.Column="1" Text="Notifiche"
                   FontFamily="OpenSansSemibold" FontSize="18" FontAttributes="Bold"
                   TextColor="{DynamicResource OnSurface}"
                   HorizontalOptions="Center" VerticalOptions="Center" />
        </Grid>

        <!-- Notification List -->
        <ScrollView Grid.Row="1" Padding="20,4,20,100">
            <CollectionView ItemsSource="{Binding Notifications}" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:NotificationItem">
                        <Border Style="{DynamicResource CardFrame}"
                                BackgroundColor="{DynamicResource SurfaceContainerHigh}"
                                Margin="0,4">
                            <VerticalStackLayout Spacing="10">
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                    <!-- Avatar -->
                                    <Border Grid.Column="0"
                                            BackgroundColor="{DynamicResource PrimaryContainer}"
                                            StrokeShape="RoundRectangle 20"
                                            WidthRequest="44" HeightRequest="44" Padding="0">
                                        <Label Text="{Binding Avatar}"
                                               FontFamily="OpenSansSemibold" FontSize="17"
                                               TextColor="{DynamicResource OnPrimaryContainer}"
                                               HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <!-- Name + Message -->
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                        <Label Text="{Binding Name}"
                                               FontFamily="OpenSansSemibold" FontSize="14" FontAttributes="Bold"
                                               TextColor="{DynamicResource OnSurface}" />
                                        <Label Text="{Binding Message}"
                                               FontFamily="OpenSansRegular" FontSize="12"
                                               TextColor="{DynamicResource TextSecondary}"
                                               LineBreakMode="TailTruncation" MaxLines="2" />
                                    </VerticalStackLayout>
                                    <Label Grid.Column="2" Text="{Binding Time}"
                                           FontFamily="OpenSansRegular" FontSize="11"
                                           TextColor="{DynamicResource Outline}"
                                           VerticalOptions="Start" Margin="0,4,0,0" />
                                </Grid>

                                <!-- Friend request buttons -->
                                <HorizontalStackLayout Spacing="8"
                                                       IsVisible="{Binding IsFriendRequest}">
                                    <Button Text="ACCETTA"
                                            FontFamily="OpenSansSemibold" FontSize="11"
                                            BackgroundColor="{DynamicResource LimeGreen}"
                                            TextColor="{DynamicResource OnSecondary}"
                                            CornerRadius="16" HeightRequest="34" Padding="16,0"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:NotificationsViewModel}}, Path=AcceptRequestCommand}"
                                            CommandParameter="{Binding .}" />
                                    <Button Text="RIFIUTA"
                                            FontFamily="OpenSansSemibold" FontSize="11"
                                            BackgroundColor="{DynamicResource SurfaceContainer}"
                                            TextColor="{DynamicResource TextSecondary}"
                                            CornerRadius="16" HeightRequest="34" Padding="16,0"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:NotificationsViewModel}}, Path=DeclineRequestCommand}"
                                            CommandParameter="{Binding .}" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </ScrollView>

    </Grid>

</ContentPage>
