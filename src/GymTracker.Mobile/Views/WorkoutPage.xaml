<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:GymTracker.Mobile.ViewModels"
    xmlns:models="clr-namespace:GymTracker.Mobile.Models"
    x:Class="GymTracker.Mobile.Views.WorkoutPage"
    x:DataType="vm:WorkoutViewModel"
    Title="WORKOUT">

    <Grid RowDefinitions="Auto,Auto,*" BackgroundColor="{StaticResource Surface}">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto"
              Padding="20,16" BackgroundColor="{StaticResource Surface}">
            <Border Grid.Column="0" BackgroundColor="{StaticResource SurfaceContainer}"
                    StrokeShape="RoundRectangle 12" Padding="8" HeightRequest="40" WidthRequest="40">
                <Label Text="📊" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>
            <Label Grid.Column="1" Text="WORKOUT"
                   FontFamily="LexendBold" FontSize="18" FontAttributes="Bold"
                   TextColor="{StaticResource OnSurface}"
                   HorizontalOptions="Center" VerticalOptions="Center" />
            <Border Grid.Column="2" BackgroundColor="{StaticResource SurfaceContainer}"
                    StrokeShape="RoundRectangle 12" Padding="8" HeightRequest="40" WidthRequest="40">
                <Label Text="🔔" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>
        </Grid>

        <!-- Subtitle -->
        <Label Grid.Row="1" Text="Le tue schede"
               FontFamily="LexendBold" FontSize="22" FontAttributes="Bold"
               TextColor="{StaticResource OnSurface}"
               Padding="20,8" />

        <Grid Grid.Row="2" Padding="20,0,20,100">

            <!-- Empty State -->
            <VerticalStackLayout IsVisible="{Binding IsEmptyState}"
                                 VerticalOptions="Center" HorizontalOptions="Center" Spacing="20">
                <Label Text="📋" FontSize="56" HorizontalTextAlignment="Center" />
                <VerticalStackLayout Spacing="6">
                    <Label Text="Nessuna scheda salvata"
                           FontFamily="LexendBold" FontSize="20" FontAttributes="Bold"
                           TextColor="{StaticResource OnSurface}"
                           HorizontalTextAlignment="Center" />
                    <Label Text="Crea una scheda personalizzata o inizia un allenamento libero."
                           FontFamily="InterRegular" FontSize="14"
                           TextColor="{StaticResource TextSecondary}"
                           HorizontalTextAlignment="Center" MaximumWidthRequest="280" />
                </VerticalStackLayout>

                <Button Text="CREA NUOVA SCHEDA"
                        Style="{StaticResource PrimaryButton}"
                        HorizontalOptions="Center" WidthRequest="240"
                        HeightRequest="56"
                        Command="{Binding CreateNewPlanCommand}" />

                <Button Text="ALLENAMENTO LIBERO"
                        Style="{StaticResource SecondaryButton}"
                        HorizontalOptions="Center" WidthRequest="240"
                        Command="{Binding StartEmptyWorkoutCommand}" />
            </VerticalStackLayout>

            <!-- Saved Plans List -->
            <ScrollView IsVisible="{Binding HasData}">
                <VerticalStackLayout Spacing="8">
                    <CollectionView ItemsSource="{Binding SavedPlans}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:WorkoutPlan">
                                <Border Style="{StaticResource CardFrame}"
                                        BackgroundColor="{StaticResource SurfaceContainerHigh}"
                                        Margin="0,4">
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="6">
                                        <Label Grid.Row="0" Grid.Column="0"
                                               Text="{Binding Name}"
                                               FontFamily="LexendBold" FontSize="16" FontAttributes="Bold"
                                               TextColor="{StaticResource OnSurface}" />
                                        <Label Grid.Row="1" Grid.Column="0"
                                               FontFamily="InterRegular" FontSize="12"
                                               TextColor="{StaticResource TextSecondary}">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="{Binding Exercises.Count}" />
                                                    <Span Text=" esercizi · " />
                                                    <Span Text="{Binding RestSeconds}" />
                                                    <Span Text="s pausa" />
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>
                                        <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                                BackgroundColor="{StaticResource LimeGreen}"
                                                StrokeShape="RoundRectangle 10" Padding="10,4"
                                                VerticalOptions="Center">
                                            <Label Text="INIZIA" FontFamily="InterBold" FontSize="10"
                                                   TextColor="{StaticResource OnSecondary}" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </ScrollView>

        </Grid>
    </Grid>

</ContentPage>
