<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:GymTracker.Mobile.ViewModels"
    xmlns:models="clr-namespace:GymTracker.Mobile.Models"
    x:Class="GymTracker.Mobile.Views.WorkoutPage"
    x:DataType="vm:WorkoutViewModel"
    Title="Workout"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*" BackgroundColor="{DynamicResource Surface}">

        <!-- Title + Bell -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Padding="20,16,20,8">
            <Label Grid.Column="0" Text="Le tue schede"
                   FontFamily="OpenSansSemibold" FontSize="22" FontAttributes="Bold"
                   TextColor="{DynamicResource OnSurface}" VerticalOptions="Center" />
            <Border Grid.Column="1" BackgroundColor="{DynamicResource SurfaceContainer}"
                    StrokeShape="RoundRectangle 12" Padding="8" HeightRequest="40" WidthRequest="40"
                    VerticalOptions="Center">
                <Label Text="⬤" FontSize="14" TextColor="{DynamicResource Primary}"
                       HorizontalOptions="Center" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBellTapped" />
                    </Label.GestureRecognizers>
                </Label>
            </Border>
        </Grid>

        <Grid Grid.Row="1" Padding="20,0,20,100">

            <!-- Empty State -->
            <VerticalStackLayout IsVisible="{Binding IsEmptyState}"
                                 VerticalOptions="Center" HorizontalOptions="Center" Spacing="20">
                <Label Text="📋" FontSize="56" HorizontalTextAlignment="Center" />
                <VerticalStackLayout Spacing="6">
                    <Label Text="Nessuna scheda salvata"
                           FontFamily="OpenSansSemibold" FontSize="20" FontAttributes="Bold"
                           TextColor="{DynamicResource OnSurface}"
                           HorizontalTextAlignment="Center" />
                    <Label Text="Crea una scheda personalizzata o inizia un allenamento libero."
                           FontFamily="OpenSansRegular" FontSize="14"
                           TextColor="{DynamicResource TextSecondary}"
                           HorizontalTextAlignment="Center" MaximumWidthRequest="280" />
                </VerticalStackLayout>

                <Button Text="CREA NUOVA SCHEDA"
                        Style="{DynamicResource PrimaryButton}"
                        HorizontalOptions="Center" WidthRequest="240"
                        HeightRequest="56"
                        Command="{Binding CreateNewPlanCommand}" />

                <Button Text="ALLENAMENTO LIBERO"
                        Style="{DynamicResource SecondaryButton}"
                        HorizontalOptions="Center" WidthRequest="240"
                        Command="{Binding StartEmptyWorkoutCommand}" />
            </VerticalStackLayout>

            <!-- Saved Plans List -->
            <ScrollView IsVisible="{Binding HasData}">
                <VerticalStackLayout Spacing="8">
                    <CollectionView ItemsSource="{Binding SavedPlans}" SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:WorkoutPlan">
                                <Border Style="{DynamicResource CardFrame}"
                                        BackgroundColor="{DynamicResource SurfaceContainerHigh}"
                                        Margin="0,4">
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="6">
                                        <Label Grid.Row="0" Grid.Column="0"
                                               Text="{Binding Name}"
                                               FontFamily="OpenSansSemibold" FontSize="16" FontAttributes="Bold"
                                               TextColor="{DynamicResource OnSurface}" />
                                        <Label Grid.Row="1" Grid.Column="0"
                                               FontFamily="OpenSansRegular" FontSize="12"
                                               TextColor="{DynamicResource TextSecondary}">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="{Binding Exercises.Count}" />
                                                    <Span Text=" esercizi · " />
                                                    <Span Text="{Binding RestSeconds}" />
                                                    <Span Text="s pausa" />
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>
                                        <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                                BackgroundColor="{DynamicResource LimeGreen}"
                                                StrokeShape="RoundRectangle 10" Padding="10,4"
                                                VerticalOptions="Center">
                                            <Label Text="INIZIA" FontFamily="OpenSansSemibold" FontSize="10"
                                                   TextColor="{DynamicResource OnSecondary}" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </ScrollView>

        </Grid>
    </Grid>

</ContentPage>
