<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:GymTracker.Mobile.ViewModels"
    x:Class="GymTracker.Mobile.Views.WorkoutPage"
    x:DataType="vm:WorkoutViewModel"
    Title="GYM LOG">

    <Grid RowDefinitions="Auto,*" BackgroundColor="{StaticResource Surface}">

        <!-- Header bar -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto"
              Padding="20,16" BackgroundColor="{StaticResource Surface}">
            <Border Grid.Column="0"
                    BackgroundColor="{StaticResource SurfaceContainer}"
                    StrokeShape="RoundRectangle 12"
                    Padding="8" HeightRequest="40" WidthRequest="40">
                <Label Text="📊" FontSize="18"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>
            <Label Grid.Column="1" Text="WORKOUT"
                   FontFamily="LexendBold" FontSize="18" FontAttributes="Bold"
                   TextColor="{StaticResource OnSurface}"
                   HorizontalOptions="Center" VerticalOptions="Center" />
            <Button Grid.Column="2"
                    Text="CREA SCHEDA"
                    FontFamily="InterBold" FontSize="10" FontAttributes="Bold"
                    TextColor="{StaticResource OnSecondary}"
                    BackgroundColor="{StaticResource LimeGreen}"
                    CornerRadius="12" HeightRequest="36" Padding="12,0" />
        </Grid>

        <!-- Content -->
        <ScrollView Grid.Row="1" Padding="20,0,20,100">
            <VerticalStackLayout Spacing="16">

                <!-- Date + Start Button -->
                <Grid ColumnDefinitions="*,Auto" Padding="0,8">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label Text="Oggi"
                               FontFamily="InterRegular" FontSize="14"
                               TextColor="{StaticResource TextSecondary}" />
                        <Label Text="Nuovo Allenamento"
                               FontFamily="LexendBold" FontSize="24" FontAttributes="Bold"
                               TextColor="{StaticResource OnSurface}" />
                    </VerticalStackLayout>
                    <Button Grid.Column="1"
                            Text="INIZIA"
                            Style="{StaticResource PrimaryButton}"
                            HeightRequest="48" WidthRequest="120"
                            FontSize="13"
                            Command="{Binding StartWorkoutCommand}" />
                </Grid>

                <!-- Suggested Exercises from a Plan -->
                <Label Text="SCHEMA PUSH (PETTO/SPALLE/TRICIPITI)"
                       FontFamily="InterBold" FontSize="11" FontAttributes="Bold"
                       TextColor="{StaticResource TextSecondary}" CharacterSpacing="0.8" />

                <!-- Exercise Card 1 -->
                <Border Style="{StaticResource CardFrame}"
                        BackgroundColor="{StaticResource SurfaceContainerHigh}">
                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto,Auto"
                          ColumnSpacing="12" RowSpacing="6">
                        <!-- Exercise Icon placeholder -->
                        <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="3"
                                BackgroundColor="{StaticResource SurfaceContainer}"
                                StrokeShape="RoundRectangle 12"
                                WidthRequest="64" HeightRequest="64" Padding="0">
                            <Label Text="🏋️" FontSize="28"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <!-- Exercise name -->
                        <Label Grid.Row="0" Grid.Column="1"
                               Text="Panca Piana con Bilanciere"
                               FontFamily="LexendBold" FontSize="15" FontAttributes="Bold"
                               TextColor="{StaticResource OnSurface}" />
                        <!-- Target -->
                        <Label Grid.Row="1" Grid.Column="1"
                               Text="Petto · Bilanciere"
                               FontFamily="InterRegular" FontSize="12"
                               TextColor="{StaticResource TextSecondary}" />
                        <!-- Sets info -->
                        <Label Grid.Row="2" Grid.Column="1"
                               Text="4 serie · 8-12 reps"
                               FontFamily="InterRegular" FontSize="12"
                               TextColor="{StaticResource Primary}" />
                        <!-- Add set button -->
                        <Border Grid.Row="0" Grid.Column="2" Grid.RowSpan="3"
                                BackgroundColor="{StaticResource SurfaceContainer}"
                                StrokeShape="RoundRectangle 12"
                                WidthRequest="44" HeightRequest="44" Padding="0">
                            <Label Text="+" FontSize="24"
                                   TextColor="{StaticResource Primary}"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                    </Grid>
                </Border>

                <!-- Exercise Card 2 -->
                <Border Style="{StaticResource CardFrame}"
                        BackgroundColor="{StaticResource SurfaceContainerHigh}">
                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto,Auto"
                          ColumnSpacing="12" RowSpacing="6">
                        <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="3"
                                BackgroundColor="{StaticResource SurfaceContainer}"
                                StrokeShape="RoundRectangle 12"
                                WidthRequest="64" HeightRequest="64" Padding="0">
                            <Label Text="🏋️" FontSize="28"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Label Grid.Row="0" Grid.Column="1"
                               Text="Shoulder Press con Manubri"
                               FontFamily="LexendBold" FontSize="15" FontAttributes="Bold"
                               TextColor="{StaticResource OnSurface}" />
                        <Label Grid.Row="1" Grid.Column="1"
                               Text="Spalle · Manubri"
                               FontFamily="InterRegular" FontSize="12"
                               TextColor="{StaticResource TextSecondary}" />
                        <Label Grid.Row="2" Grid.Column="1"
                               Text="3 serie · 10-15 reps"
                               FontFamily="InterRegular" FontSize="12"
                               TextColor="{StaticResource Primary}" />
                        <Border Grid.Row="0" Grid.Column="2" Grid.RowSpan="3"
                                BackgroundColor="{StaticResource SurfaceContainer}"
                                StrokeShape="RoundRectangle 12"
                                WidthRequest="44" HeightRequest="44" Padding="0">
                            <Label Text="+" FontSize="24"
                                   TextColor="{StaticResource Primary}"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                    </Grid>
                </Border>

                <!-- Exercise Card 3 -->
                <Border Style="{StaticResource CardFrame}"
                        BackgroundColor="{StaticResource SurfaceContainerHigh}">
                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto,Auto"
                          ColumnSpacing="12" RowSpacing="6">
                        <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="3"
                                BackgroundColor="{StaticResource SurfaceContainer}"
                                StrokeShape="RoundRectangle 12"
                                WidthRequest="64" HeightRequest="64" Padding="0">
                            <Label Text="🏋️" FontSize="28"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Label Grid.Row="0" Grid.Column="1"
                               Text="Push Down ai Cavi"
                               FontFamily="LexendBold" FontSize="15" FontAttributes="Bold"
                               TextColor="{StaticResource OnSurface}" />
                        <Label Grid.Row="1" Grid.Column="1"
                               Text="Tricipiti · Cavi"
                               FontFamily="InterRegular" FontSize="12"
                               TextColor="{StaticResource TextSecondary}" />
                        <Label Grid.Row="2" Grid.Column="1"
                               Text="3 serie · 12-15 reps"
                               FontFamily="InterRegular" FontSize="12"
                               TextColor="{StaticResource Primary}" />
                        <Border Grid.Row="0" Grid.Column="2" Grid.RowSpan="3"
                                BackgroundColor="{StaticResource SurfaceContainer}"
                                StrokeShape="RoundRectangle 12"
                                WidthRequest="44" HeightRequest="44" Padding="0">
                            <Label Text="+" FontSize="24"
                                   TextColor="{StaticResource Primary}"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                    </Grid>
                </Border>

                <!-- Add Exercise button -->
                <Border Style="{StaticResource CardFrame}"
                        BackgroundColor="{StaticResource SurfaceContainer}"
                        Stroke="{StaticResource Primary}" StrokeThickness="1"
                        Padding="0" HeightRequest="56">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12"
                          HorizontalOptions="Center" VerticalOptions="Center">
                        <Label Grid.Column="0" Text="+" FontSize="22"
                               TextColor="{StaticResource Primary}" VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="Aggiungi esercizio"
                               FontFamily="InterRegular" FontSize="15"
                               TextColor="{StaticResource Primary}" VerticalOptions="Center" />
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
