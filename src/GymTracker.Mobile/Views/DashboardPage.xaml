<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:GymTracker.Mobile.ViewModels"
    x:Class="GymTracker.Mobile.Views.DashboardPage"
    x:DataType="vm:DashboardViewModel"
    Title="IRON RANK"
    Shell.TabBarIsVisible="True">

    <ScrollView>
        <VerticalStackLayout Padding="20,24" Spacing="24">

            <!-- Greeting -->
            <VerticalStackLayout Spacing="4">
                <Label Text="IRON RANK"
                       FontFamily="LexendBold" FontSize="32" FontAttributes="Bold"
                       TextColor="{StaticResource OnSurface}" />
                <Label Text="Il fitness diventa leggenda"
                       FontFamily="InterRegular" FontSize="16"
                       TextColor="{StaticResource TextSecondary}" />
            </VerticalStackLayout>

            <!-- Streak Banner -->
            <Border Style="{StaticResource CardFrame}"
                    BackgroundColor="{StaticResource SurfaceContainer}">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                    <Label Grid.Column="0" Text="🔥" FontSize="36" VerticalOptions="Center" />
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                        <Label Text="STREAK ATTIVO"
                               FontFamily="InterBold" FontSize="11" FontAttributes="Bold"
                               TextColor="{StaticResource TextSecondary}"
                               CharacterSpacing="0.8" />
                        <Label Text="{Binding StreakText}"
                               FontFamily="LexendBold" FontSize="28" FontAttributes="Bold"
                               TextColor="{StaticResource LimeGreen}" />
                    </VerticalStackLayout>
                    <Label Grid.Column="2" Text="{Binding LeaderboardPosition, StringFormat='#{0}'}"
                           FontFamily="LexendBold" FontSize="40" FontAttributes="Bold"
                           TextColor="{StaticResource Primary}"
                           VerticalOptions="Center" />
                </Grid>
            </Border>

            <!-- Quick Stats 2x2 Grid -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto"
                  ColumnSpacing="12" RowSpacing="12">

                <!-- Weight -->
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CardFrame}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="PESO"
                               FontFamily="InterBold" FontSize="11" FontAttributes="Bold"
                               TextColor="{StaticResource TextSecondary}" CharacterSpacing="0.8" />
                        <Label Text="{Binding CurrentWeight}"
                               FontFamily="LexendBold" FontSize="36" FontAttributes="Bold"
                               TextColor="{StaticResource OnSurface}" />
                        <Label Text="Ultima rilevazione"
                               FontFamily="InterRegular" FontSize="12"
                               TextColor="{StaticResource Outline}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Position -->
                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource CardFrame}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="CLASSIFICA"
                               FontFamily="InterBold" FontSize="11" FontAttributes="Bold"
                               TextColor="{StaticResource TextSecondary}" CharacterSpacing="0.8" />
                        <Label Text="{Binding LeaderboardPosition, StringFormat='#{0}'}"
                               FontFamily="LexendBold" FontSize="36" FontAttributes="Bold"
                               TextColor="{StaticResource Primary}" />
                        <Label Text="Tra i tuoi amici"
                               FontFamily="InterRegular" FontSize="12"
                               TextColor="{StaticResource Outline}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Weekly Volume -->
                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource CardFrame}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="VOLUME 7 GIORNI"
                               FontFamily="InterBold" FontSize="11" FontAttributes="Bold"
                               TextColor="{StaticResource TextSecondary}" CharacterSpacing="0.8" />
                        <Label Text="{Binding WeeklyVolume}"
                               FontFamily="LexendBold" FontSize="36" FontAttributes="Bold"
                               TextColor="{StaticResource LimeGreen}" />
                        <Label Text="Peso × Ripetizioni"
                               FontFamily="InterRegular" FontSize="12"
                               TextColor="{StaticResource Outline}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Last Workout -->
                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardFrame}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="ULTIMO ALLENAMENTO"
                               FontFamily="InterBold" FontSize="11" FontAttributes="Bold"
                               TextColor="{StaticResource TextSecondary}" CharacterSpacing="0.8" />
                        <Label Text="{Binding LastWorkoutSummary}"
                               FontFamily="InterRegular" FontSize="16"
                               TextColor="{StaticResource OnSurface}" />
                        <Label Text="Non hai ancora fatto nulla? Inizia ora!"
                               FontFamily="InterRegular" FontSize="12"
                               TextColor="{StaticResource LimeGreen}" />
                    </VerticalStackLayout>
                </Border>

            </Grid>

            <!-- Quick Actions -->
            <Grid ColumnDefinitions="*,12,*" RowDefinitions="Auto,Auto" RowSpacing="12">
                <Button Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                        Text="INIZIA ALLENAMENTO"
                        Style="{StaticResource PrimaryButton}"
                        HeightRequest="56"
                        FontSize="15"
                        FontFamily="InterBold"
                        FontAttributes="Bold" />
                <Button Grid.Row="1" Grid.Column="0"
                        Text="ESERCIZI"
                        Style="{StaticResource SecondaryButton}"
                        HeightRequest="52" />
                <Button Grid.Row="1" Grid.Column="2"
                        Text="AMICI"
                        Style="{StaticResource SecondaryButton}"
                        HeightRequest="52" />
            </Grid>

            <!-- Recent Activity (placeholder) -->
            <Border Style="{StaticResource CardFrame}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="ATTIVITÀ RECENTE"
                           FontFamily="InterBold" FontSize="11" FontAttributes="Bold"
                           TextColor="{StaticResource TextSecondary}" CharacterSpacing="0.8" />
                    <Label Text="Nessun allenamento registrato questa settimana."
                           FontFamily="InterRegular" FontSize="14"
                           TextColor="{StaticResource Outline}" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
