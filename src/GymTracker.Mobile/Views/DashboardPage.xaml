<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:GymTracker.Mobile.ViewModels"
    x:Class="GymTracker.Mobile.Views.DashboardPage"
    x:DataType="vm:DashboardViewModel"
    Title="Home"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*" BackgroundColor="{StaticResource Surface}">

        <ScrollView Padding="20,16,20,100">
            <VerticalStackLayout Spacing="16">

                <!-- Greeting + Bell -->
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label Text="Oggi" FontFamily="InterRegular" FontSize="14" TextColor="{StaticResource TextSecondary}" />
                        <Label Text="Ciao, IronAthlete" FontFamily="LexendBold" FontSize="26" FontAttributes="Bold"
                               TextColor="{StaticResource OnSurface}" />
                    </VerticalStackLayout>
                    <Border Grid.Column="1" BackgroundColor="{StaticResource SurfaceContainer}"
                            StrokeShape="RoundRectangle 12" Padding="8" HeightRequest="40" WidthRequest="40"
                            VerticalOptions="Center">
                        <Label x:Name="BellIcon" Text="⬤" FontSize="14"
                               TextColor="{StaticResource Primary}"
                               HorizontalOptions="Center" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnBellTapped" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>
                </Grid>

                <!-- Streak + Rank -->
                <Border Style="{StaticResource CardFrame}" BackgroundColor="{StaticResource SurfaceContainerHigh}">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                        <Label Grid.Column="0" Text="🔥" FontSize="36" VerticalOptions="Center" />
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="STREAK ATTIVO" FontFamily="InterBold" FontSize="11" FontAttributes="Bold"
                                   TextColor="{StaticResource TextSecondary}" CharacterSpacing="0.8" />
                            <Label Text="{Binding StreakText}" FontFamily="LexendBold" FontSize="28" FontAttributes="Bold"
                                   TextColor="{StaticResource LimeGreen}" />
                        </VerticalStackLayout>
                        <Label Grid.Column="2" Text="{Binding LeaderboardPosition, StringFormat='#{0}'}"
                               FontFamily="LexendBold" FontSize="40" FontAttributes="Bold"
                               TextColor="{StaticResource Primary}" VerticalOptions="Center" />
                    </Grid>
                </Border>

                <!-- Stats 2x2 -->
                <Grid ColumnDefinitions="*,12,*" RowDefinitions="Auto,12,Auto">
                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource CardFrame}">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="PESO" FontFamily="InterBold" FontSize="11" FontAttributes="Bold"
                                   TextColor="{StaticResource TextSecondary}" CharacterSpacing="0.8" />
                            <Label Text="{Binding CurrentWeight}" FontFamily="LexendBold" FontSize="36" FontAttributes="Bold"
                                   TextColor="{StaticResource OnSurface}" />
                            <Label Text="Ultima rilevazione" FontFamily="InterRegular" FontSize="12"
                                   TextColor="{StaticResource Outline}" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource CardFrame}">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="CLASSIFICA" FontFamily="InterBold" FontSize="11" FontAttributes="Bold"
                                   TextColor="{StaticResource TextSecondary}" CharacterSpacing="0.8" />
                            <Label Text="{Binding LeaderboardPosition, StringFormat='#{0}'}"
                                   FontFamily="LexendBold" FontSize="36" FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}" />
                            <Label Text="Tra i tuoi amici" FontFamily="InterRegular" FontSize="12"
                                   TextColor="{StaticResource Outline}" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource CardFrame}">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="VOLUME 7 GIORNI" FontFamily="InterBold" FontSize="11" FontAttributes="Bold"
                                   TextColor="{StaticResource TextSecondary}" CharacterSpacing="0.8" />
                            <Label Text="{Binding WeeklyVolume}" FontFamily="LexendBold" FontSize="36" FontAttributes="Bold"
                                   TextColor="{StaticResource LimeGreen}" />
                            <Label Text="Peso x Ripetizioni" FontFamily="InterRegular" FontSize="12"
                                   TextColor="{StaticResource Outline}" />
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Row="2" Grid.Column="2" Style="{StaticResource CardFrame}">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="ULTIMO ALLENAMENTO" FontFamily="InterBold" FontSize="11" FontAttributes="Bold"
                                   TextColor="{StaticResource TextSecondary}" CharacterSpacing="0.8" />
                            <Label Text="{Binding LastWorkoutSummary}" FontFamily="InterRegular" FontSize="16"
                                   TextColor="{StaticResource OnSurface}" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- CTA -->
                <Grid ColumnDefinitions="*,12,*">
                    <Button Grid.Column="0" Text="ALLENAMENTO" Style="{StaticResource PrimaryButton}" HeightRequest="56" FontSize="15" FontFamily="InterBold" FontAttributes="Bold" />
                    <Button Grid.Column="2" Text="ESERCIZI" Style="{StaticResource SecondaryButton}" HeightRequest="52" />
                </Grid>

                <!-- Friend Feed -->
                <Label Text="FEED AMICI" FontFamily="InterBold" FontSize="11" FontAttributes="Bold"
                       TextColor="{StaticResource TextSecondary}" CharacterSpacing="0.8" Margin="0,4,0,0" />

                <!-- Friend 1: Sofia -->
                <Border Style="{StaticResource CardFrame}" BackgroundColor="{StaticResource SurfaceContainerHigh}">
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                            <Border Grid.Column="0" BackgroundColor="{StaticResource PrimaryContainer}"
                                    StrokeShape="RoundRectangle 20" WidthRequest="40" HeightRequest="40" Padding="0">
                                <Label Text="S" FontFamily="LexendBold" FontSize="16"
                                       TextColor="{StaticResource OnPrimaryContainer}"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                                <Label Text="Sofia" FontFamily="LexendBold" FontSize="14" FontAttributes="Bold"
                                       TextColor="{StaticResource OnSurface}" />
                                <Label Text="Oggi, 08:30 · Streak 🔥 12" FontFamily="InterRegular" FontSize="11"
                                       TextColor="{StaticResource LimeGreen}" />
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="👑" FontSize="20" VerticalOptions="Center" />
                        </Grid>
                        <Label Text="Panca Piana 4×10@80kg · Squat 4×8@100kg · Stacchi 3×6@130kg"
                               FontFamily="InterRegular" FontSize="13" TextColor="{StaticResource TextSecondary}" />
                        <Label Text="4,200 kg" FontFamily="LexendBold" FontSize="20" FontAttributes="Bold"
                               TextColor="{StaticResource ElectricBlue}" />

                        <!-- Comments -->
                        <Border BackgroundColor="{StaticResource SurfaceContainer}" StrokeShape="RoundRectangle 8" Padding="12,10">
                            <VerticalStackLayout Spacing="6">
                                <HorizontalStackLayout Spacing="8">
                                    <Border BackgroundColor="{StaticResource PrimaryContainer}" StrokeShape="RoundRectangle 10" WidthRequest="24" HeightRequest="24" Padding="0">
                                        <Label Text="M" FontFamily="InterBold" FontSize="10" TextColor="{StaticResource OnPrimaryContainer}"
                                               HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <VerticalStackLayout Spacing="2">
                                        <HorizontalStackLayout Spacing="6">
                                            <Label Text="Marco" FontFamily="InterBold" FontSize="11" TextColor="{StaticResource Primary}" />
                                            <Label Text="2m fa" FontFamily="InterRegular" FontSize="10" TextColor="{StaticResource TextSecondary}" />
                                        </HorizontalStackLayout>
                                        <Label Text="Ma sei un mostro! 💪 Quei 100kg di squat fanno paura" FontFamily="InterRegular" FontSize="12"
                                               TextColor="{StaticResource OnSurface}" />
                                    </VerticalStackLayout>
                                </HorizontalStackLayout>
                                <BoxView HeightRequest="0.5" Color="{StaticResource OutlineVariant}" />
                                <HorizontalStackLayout Spacing="8">
                                    <Border BackgroundColor="{StaticResource SurfaceContainerHigh}" StrokeShape="RoundRectangle 10" WidthRequest="24" HeightRequest="24" Padding="0">
                                        <Label Text="S" FontFamily="InterBold" FontSize="10" TextColor="{StaticResource LimeGreen}"
                                               HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <VerticalStackLayout Spacing="2">
                                        <HorizontalStackLayout Spacing="6">
                                            <Label Text="Sofia" FontFamily="InterBold" FontSize="11" TextColor="{StaticResource LimeGreen}" />
                                            <Label Text="1m fa" FontFamily="InterRegular" FontSize="10" TextColor="{StaticResource TextSecondary}" />
                                        </HorizontalStackLayout>
                                        <Label Text="Grazie! Tu però mi stai raggiungendo... #4 non è male 😉" FontFamily="InterRegular" FontSize="12"
                                               TextColor="{StaticResource OnSurface}" />
                                    </VerticalStackLayout>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                        <Label Text="🔥 Sfida · 💬 Commenta" FontFamily="InterBold" FontSize="11"
                               TextColor="{StaticResource Primary}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Friend 2: Luca -->
                <Border Style="{StaticResource CardFrame}" BackgroundColor="{StaticResource SurfaceContainerHigh}">
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                            <Border Grid.Column="0" BackgroundColor="{StaticResource SurfaceContainer}"
                                    StrokeShape="RoundRectangle 20" WidthRequest="40" HeightRequest="40" Padding="0">
                                <Label Text="L" FontFamily="LexendBold" FontSize="16"
                                       TextColor="{StaticResource TextSecondary}"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                                <Label Text="Luca" FontFamily="LexendBold" FontSize="14" FontAttributes="Bold"
                                       TextColor="{StaticResource OnSurface}" />
                                <Label Text="Ieri, 19:00 · Streak 🔥 8" FontFamily="InterRegular" FontSize="11"
                                       TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>
                        </Grid>
                        <Label Text="Shoulder Press 3×12@30kg · Lat Machine 4×10@65kg · Curl 3×12@16kg"
                               FontFamily="InterRegular" FontSize="13" TextColor="{StaticResource TextSecondary}" />
                        <Label Text="2,100 kg" FontFamily="LexendBold" FontSize="20" FontAttributes="Bold"
                               TextColor="{StaticResource Primary}" />
                        <Border BackgroundColor="{StaticResource SurfaceContainer}" StrokeShape="RoundRectangle 8" Padding="12,10">
                            <HorizontalStackLayout Spacing="8">
                                <Border BackgroundColor="{StaticResource PrimaryContainer}" StrokeShape="RoundRectangle 10" WidthRequest="24" HeightRequest="24" Padding="0">
                                    <Label Text="M" FontFamily="InterBold" FontSize="10" TextColor="{StaticResource OnPrimaryContainer}"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <VerticalStackLayout Spacing="2">
                                    <HorizontalStackLayout Spacing="6">
                                        <Label Text="Tu" FontFamily="InterBold" FontSize="11" TextColor="{StaticResource Primary}" />
                                        <Label Text="5h fa" FontFamily="InterRegular" FontSize="10" TextColor="{StaticResource TextSecondary}" />
                                    </HorizontalStackLayout>
                                    <Label Text="Bella Luca! Domani spalle anche io, ti raggiungo 💪" FontFamily="InterRegular" FontSize="12"
                                           TextColor="{StaticResource OnSurface}" />
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                        </Border>
                        <Label Text="🔥 Sfida · 💬 Commenta" FontFamily="InterBold" FontSize="11"
                               TextColor="{StaticResource Primary}" />
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
