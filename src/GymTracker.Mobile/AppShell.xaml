<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Forge.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Forge.Views"
    Shell.FlyoutBehavior="Disabled"
    Shell.BackgroundColor="{DynamicResource Surface}"
    Shell.ForegroundColor="{DynamicResource OnSurface}"
    Shell.TabBarBackgroundColor="{DynamicResource SurfaceContainerLow}"
    Shell.TabBarForegroundColor="{DynamicResource Primary}"
    Shell.TabBarUnselectedColor="{DynamicResource Outline}"
    Shell.TabBarTitleColor="{DynamicResource Primary}">

    <TabBar>
        <ShellContent
            Title="Dashboard"
            Icon="icon_dashboard.svg"
            ContentTemplate="{DataTemplate views:HomePage}"
            Route="dashboard" />

        <ShellContent
            Title="Feed"
            Icon="icon_social.svg"
            ContentTemplate="{DataTemplate views:FeedPage}"
            Route="feed" />

        <ShellContent
            Title="Stats"
            Icon="icon_profile.svg"
            ContentTemplate="{DataTemplate views:StatsPage}"
            Route="stats" />
    </TabBar>

</Shell>
