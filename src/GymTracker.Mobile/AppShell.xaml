<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="GymTracker.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:GymTracker.Mobile.Views"
    Shell.FlyoutBehavior="Disabled"
    Shell.BackgroundColor="#131313"
    Shell.ForegroundColor="#e5e2e1"
    Shell.TabBarBackgroundColor="#1c1b1b"
    Shell.TabBarForegroundColor="#c3f5ff"
    Shell.TabBarUnselectedColor="#849396"
    Shell.TabBarTitleColor="#c3f5ff">

    <TabBar>
        <ShellContent
            Title="Dashboard"
            Icon="icon_dashboard.svg"
            ContentTemplate="{DataTemplate views:HomePage}"
            Route="dashboard" />

        <ShellContent
            Title="Feed"
            Icon="icon_social.svg"
            ContentTemplate="{DataTemplate views:FeedPage}"
            Route="feed" />

        <ShellContent
            Title="Stats"
            Icon="icon_profile.svg"
            ContentTemplate="{DataTemplate views:StatsPage}"
            Route="stats" />
    </TabBar>

</Shell>
