<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Fitness Core Light Palette -->

    <Color x:Key="Surface">#f8f9ff</Color>
    <Color x:Key="SurfaceDim">#ccdbf4</Color>
    <Color x:Key="SurfaceBright">#f8f9ff</Color>
    <Color x:Key="SurfaceContainerLowest">#ffffff</Color>
    <Color x:Key="SurfaceContainerLow">#eff4ff</Color>
    <Color x:Key="SurfaceContainer">#e6eeff</Color>
    <Color x:Key="SurfaceContainerHigh">#dde9ff</Color>
    <Color x:Key="SurfaceContainerHighest">#d5e3fd</Color>
    <Color x:Key="SurfaceVariant">#d5e3fd</Color>

    <Color x:Key="OnSurface">#0d1c2f</Color>
    <Color x:Key="OnSurfaceVariant">#434656</Color>

    <Color x:Key="Primary">#003ec7</Color>
    <Color x:Key="OnPrimary">#ffffff</Color>
    <Color x:Key="PrimaryContainer">#0052ff</Color>
    <Color x:Key="OnPrimaryContainer">#dfe3ff</Color>

    <Color x:Key="Secondary">#076e00</Color>
    <Color x:Key="OnSecondary">#ffffff</Color>
    <Color x:Key="SecondaryContainer">#18f900</Color>
    <Color x:Key="OnSecondaryContainer">#076d00</Color>

    <Color x:Key="Tertiary">#5c24c6</Color>
    <Color x:Key="OnTertiary">#ffffff</Color>
    <Color x:Key="TertiaryContainer">#7544df</Color>

    <Color x:Key="Error">#ba1a1a</Color>
    <Color x:Key="OnError">#ffffff</Color>
    <Color x:Key="ErrorContainer">#ffdad6</Color>

    <Color x:Key="Outline">#737688</Color>
    <Color x:Key="OutlineVariant">#c3c5d9</Color>

    <Color x:Key="ElectricBlue">#0052ff</Color>
    <Color x:Key="LimeGreen">#076e00</Color>
    <Color x:Key="AlertRed">#ba1a1a</Color>
    <Color x:Key="CardBackground">#ffffff</Color>
    <Color x:Key="PureBlack">#000000</Color>

    <Color x:Key="PageBackground">#f8f9ff</Color>
    <Color x:Key="TextPrimary">#0d1c2f</Color>
    <Color x:Key="TextSecondary">#434656</Color>

</ResourceDictionary>
