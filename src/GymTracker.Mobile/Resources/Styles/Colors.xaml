<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Iron Rank Performance Minimalist Palette -->
    <!-- Surface (backgrounds) -->
    <Color x:Key="Surface">#131313</Color>
    <Color x:Key="SurfaceDim">#131313</Color>
    <Color x:Key="SurfaceBright">#393939</Color>
    <Color x:Key="SurfaceContainerLowest">#0E0E0E</Color>
    <Color x:Key="SurfaceContainerLow">#1C1B1B</Color>
    <Color x:Key="SurfaceContainer">#201F1F</Color>
    <Color x:Key="SurfaceContainerHigh">#2A2A2A</Color>
    <Color x:Key="SurfaceContainerHighest">#353534</Color>
    <Color x:Key="SurfaceVariant">#353534</Color>

    <!-- On-surface (text) -->
    <Color x:Key="OnSurface">#E5E2E1</Color>
    <Color x:Key="OnSurfaceVariant">#C1C6D7</Color>

    <!-- Primary: Electric Blue -->
    <Color x:Key="Primary">#ADC6FF</Color>
    <Color x:Key="OnPrimary">#002E69</Color>
    <Color x:Key="PrimaryContainer">#4B8EFF</Color>
    <Color x:Key="OnPrimaryContainer">#00285C</Color>
    <Color x:Key="PrimaryFixed">#D8E2FF</Color>
    <Color x:Key="PrimaryFixedDim">#ADC6FF</Color>

    <!-- Secondary: Lime Green -->
    <Color x:Key="Secondary">#FFFFFF</Color>
    <Color x:Key="OnSecondary">#283500</Color>
    <Color x:Key="SecondaryContainer">#C3F400</Color>
    <Color x:Key="OnSecondaryContainer">#556D00</Color>

    <!-- Tertiary: Red -->
    <Color x:Key="Tertiary">#FFB4AA</Color>
    <Color x:Key="OnTertiary">#690003</Color>
    <Color x:Key="TertiaryContainer">#FF5545</Color>

    <!-- Error -->
    <Color x:Key="Error">#FFB4AB</Color>
    <Color x:Key="OnError">#690005</Color>
    <Color x:Key="ErrorContainer">#93000A</Color>

    <!-- Outline -->
    <Color x:Key="Outline">#8B90A0</Color>
    <Color x:Key="OutlineVariant">#414755</Color>

    <!-- Convenience aliases for the design system -->
    <Color x:Key="ElectricBlue">#007AFF</Color>
    <Color x:Key="LimeGreen">#CCFF00</Color>
    <Color x:Key="AlertRed">#FF3B30</Color>
    <Color x:Key="PureBlack">#000000</Color>
    <Color x:Key="CardBackground">#1C1C1E</Color>

    <!-- Standard MAUI color overrides -->
    <Color x:Key="PageBackground">#131313</Color>
    <Color x:Key="TextPrimary">#E5E2E1</Color>
    <Color x:Key="TextSecondary">#C1C6D7</Color>

</ResourceDictionary>
