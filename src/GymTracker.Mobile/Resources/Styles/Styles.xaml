<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Shell styling -->
    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="{DynamicResource Surface}" />
        <Setter Property="Shell.ForegroundColor" Value="{DynamicResource OnSurface}" />
        <Setter Property="Shell.TitleColor" Value="{DynamicResource OnSurface}" />
        <Setter Property="Shell.TabBarBackgroundColor" Value="{DynamicResource SurfaceContainerLow}" />
        <Setter Property="Shell.TabBarForegroundColor" Value="{DynamicResource Primary}" />
        <Setter Property="Shell.TabBarUnselectedColor" Value="{DynamicResource Outline}" />
        <Setter Property="Shell.TabBarTitleColor" Value="{DynamicResource Primary}" />
    </Style>

    <!-- Navigation page -->
    <Style TargetType="NavigationPage">
        <Setter Property="BarBackgroundColor" Value="{DynamicResource Surface}" />
        <Setter Property="BarTextColor" Value="{DynamicResource OnSurface}" />
    </Style>

    <!-- Page -->
    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="{DynamicResource PageBackground}" />
    </Style>

    <!-- Labels -->
    <Style x:Key="DisplayMetric" TargetType="Label">
        <Setter Property="FontFamily" Value="SpaceGrotesk" />
        <Setter Property="FontSize" Value="48" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{DynamicResource OnSurface}" />
    </Style>

    <Style x:Key="H1Bold" TargetType="Label">
        <Setter Property="FontFamily" Value="SpaceGrotesk" />
        <Setter Property="FontSize" Value="32" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{DynamicResource OnSurface}" />
    </Style>

    <Style x:Key="H2Bold" TargetType="Label">
        <Setter Property="FontFamily" Value="SpaceGrotesk" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{DynamicResource OnSurface}" />
    </Style>

    <Style x:Key="BodyLg" TargetType="Label">
        <Setter Property="FontFamily" Value="Inter" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="TextColor" Value="{DynamicResource TextPrimary}" />
    </Style>

    <Style x:Key="BodyMd" TargetType="Label">
        <Setter Property="FontFamily" Value="Inter" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextColor" Value="{DynamicResource TextPrimary}" />
    </Style>

    <Style x:Key="LabelCaps" TargetType="Label">
        <Setter Property="FontFamily" Value="Lexend" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{DynamicResource TextSecondary}" />
        <Setter Property="CharacterSpacing" Value="0.6" />
    </Style>

    <Style x:Key="PageTitle" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{DynamicResource OnSurface}" />
        <Setter Property="Margin" Value="20,20,20,8" />
    </Style>

    <!-- Cards -->
    <Style x:Key="CardFrame" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{DynamicResource CardBackground}" />
        <Setter Property="Stroke" Value="{DynamicResource OutlineVariant}" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="16" />
            </Setter.Value>
        </Setter>
        <Setter Property="Padding" Value="16" />
    </Style>

    <!-- Primary button -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{DynamicResource LimeGreen}" />
        <Setter Property="TextColor" Value="{DynamicResource OnSecondary}" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CornerRadius" Value="24" />
        <Setter Property="HeightRequest" Value="50" />
        <Setter Property="Padding" Value="24,0" />
    </Style>

    <!-- Secondary button -->
    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{DynamicResource Primary}" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="BorderColor" Value="{DynamicResource Primary}" />
        <Setter Property="BorderWidth" Value="2" />
        <Setter Property="CornerRadius" Value="24" />
        <Setter Property="HeightRequest" Value="50" />
        <Setter Property="Padding" Value="24,0" />
    </Style>

    <!-- Entry fields -->
    <Style x:Key="DarkEntry" TargetType="Entry">
        <Setter Property="BackgroundColor" Value="{DynamicResource SurfaceContainer}" />
        <Setter Property="TextColor" Value="{DynamicResource OnSurface}" />
        <Setter Property="PlaceholderColor" Value="{DynamicResource Outline}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="HeightRequest" Value="50" />
        <Setter Property="ReturnType" Value="Next" />
    </Style>

    <!-- Activity indicator -->
    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{DynamicResource Primary}" />
    </Style>

    <!-- Error label -->
    <Style x:Key="ErrorLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{DynamicResource AlertRed}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Margin" Value="0,4,0,0" />
    </Style>

    <!-- Empty state -->
    <Style x:Key="EmptyStateLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{DynamicResource TextSecondary}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="HorizontalTextAlignment" Value="Center" />
        <Setter Property="Margin" Value="20" />
    </Style>

</ResourceDictionary>
