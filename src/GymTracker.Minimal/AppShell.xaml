<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="GymTracker.Minimal.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:GymTracker.Minimal.Views"
    Shell.FlyoutBehavior="Disabled">

    <TabBar>
        <ShellContent Title="Home" Icon="icon_dashboard.svg"
                      ContentTemplate="{DataTemplate views:DashboardPage}" Route="dashboard" />
        <ShellContent Title="Workout" Icon="icon_dumbbell.svg"
                      ContentTemplate="{DataTemplate views:WorkoutPage}" Route="workout" />
        <ShellContent Title="Esercizi" Icon="icon_search.svg"
                      ContentTemplate="{DataTemplate views:CatalogPage}" Route="catalog" />
        <ShellContent Title="Social" Icon="icon_social.svg"
                      ContentTemplate="{DataTemplate views:SocialPage}" Route="social" />
        <ShellContent Title="Profilo" Icon="icon_profile.svg"
                      ContentTemplate="{DataTemplate views:ProfilePage}" Route="profile" />
    </TabBar>

</Shell>
