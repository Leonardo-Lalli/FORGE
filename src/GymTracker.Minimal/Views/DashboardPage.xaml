<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:GymTracker.Minimal.ViewModels"
    x:Class="GymTracker.Minimal.Views.DashboardPage"
    x:DataType="vm:DashboardViewModel"
    Title="GymTracker">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">

            <!-- Greeting -->
            <Label Text="Ciao, IronAthlete"
                   FontSize="24" FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}" />
            <Label Text="Pronto per oggi?"
                   FontSize="14" TextColor="{StaticResource TextSecondary}" />

            <!-- Streak Bar -->
            <Border Style="{StaticResource Card}">
                <HorizontalStackLayout Spacing="12">
                    <Label Text="🔥" FontSize="28" VerticalOptions="Center" />
                    <VerticalStackLayout>
                        <Label Text="Streak attivo" FontSize="12" TextColor="{StaticResource TextSecondary}" />
                        <Label Text="{Binding StreakText}" FontSize="22" FontAttributes="Bold"
                               TextColor="{StaticResource Accent}" />
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </Border>

            <!-- Stats Grid -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Peso" FontSize="12" TextColor="{StaticResource TextSecondary}" />
                        <Label Text="{Binding CurrentWeight}" Style="{StaticResource MetricValue}" />
                        <Label Text="Ultima rilevazione" FontSize="11" TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Classifica" FontSize="12" TextColor="{StaticResource TextSecondary}" />
                        <Label Text="{Binding LeaderboardPosition, StringFormat='#{0}'}"
                               Style="{StaticResource MetricValue}" TextColor="{StaticResource Primary}" />
                        <Label Text="Tra i tuoi amici" FontSize="11" TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Volume 7gg" FontSize="12" TextColor="{StaticResource TextSecondary}" />
                        <Label Text="{Binding WeeklyVolume}" FontSize="22" FontAttributes="Bold"
                               TextColor="{StaticResource Accent}" />
                        <Label Text="Peso x Ripetizioni" FontSize="11" TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Ultimo allenamento" FontSize="12" TextColor="{StaticResource TextSecondary}" />
                        <Label Text="{Binding LastWorkoutSummary}" FontSize="14"
                               TextColor="{StaticResource TextPrimary}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- CTA -->
            <Button Text="INIZIA ALLENAMENTO" Style="{StaticResource PrimaryButton}" HorizontalOptions="Fill" />
            <Button Text="ESPLORA ESERCIZI" Style="{StaticResource SecondaryButton}" HorizontalOptions="Fill" />

            <!-- Recent -->
            <Border Style="{StaticResource Card}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Attività recente" FontSize="13" FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" />
                    <Label Text="Nessun allenamento questa settimana."
                           FontSize="13" TextColor="{StaticResource TextSecondary}" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
