<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:GymTracker.Minimal.ViewModels"
    x:Class="GymTracker.Minimal.Views.SocialPage"
    x:DataType="vm:SocialViewModel"
    Title="Social">

    <Grid RowDefinitions="*" Padding="16">

        <VerticalStackLayout IsVisible="{Binding IsEmptyState}"
                             VerticalOptions="Center" HorizontalOptions="Center" Spacing="20">
            <Label Text="🤝" FontSize="56" HorizontalTextAlignment="Center" />
            <Label Text="Nessun amico... ancora!"
                   FontSize="20" FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}"
                   HorizontalTextAlignment="Center" />
            <Label Text="Connettiti con altri atleti e scala la classifica."
                   FontSize="14" TextColor="{StaticResource TextSecondary}"
                   HorizontalTextAlignment="Center" />
            <Button Text="CERCA AMICI" Style="{StaticResource PrimaryButton}"
                    HorizontalOptions="Center" WidthRequest="200" />
        </VerticalStackLayout>

    </Grid>

</ContentPage>
