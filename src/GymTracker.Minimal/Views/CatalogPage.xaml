<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:GymTracker.Minimal.ViewModels"
    x:Class="GymTracker.Minimal.Views.CatalogPage"
    x:DataType="vm:CatalogViewModel"
    Title="Esercizi">

    <Grid RowDefinitions="Auto,*" Padding="16,12" RowSpacing="12">

        <SearchBar Grid.Row="0" Placeholder="Cerca esercizio..."
                   Text="{Binding SearchText}"
                   SearchCommand="{Binding SearchCommand}" />

        <Grid Grid.Row="1">
            <VerticalStackLayout IsVisible="{Binding IsBusy}"
                                 VerticalOptions="Center" HorizontalOptions="Center" Spacing="12">
                <ActivityIndicator IsRunning="{Binding IsBusy}" />
                <Label Text="Caricamento..." FontSize="13" TextColor="{StaticResource TextSecondary}" />
            </VerticalStackLayout>

            <VerticalStackLayout IsVisible="{Binding HasError}"
                                 VerticalOptions="Center" HorizontalOptions="Center" Spacing="12">
                <Label Text="{Binding ErrorMessage}" Style="{StaticResource ErrorLabel}" />
                <Button Text="Riprova" Style="{StaticResource SecondaryButton}"
                        HorizontalOptions="Center" Command="{Binding RefreshCommand}" />
            </VerticalStackLayout>

            <VerticalStackLayout IsVisible="{Binding IsEmptyState}"
                                 VerticalOptions="Center" HorizontalOptions="Center" Spacing="12">
                <Label Text="🔍" FontSize="40" HorizontalTextAlignment="Center" />
                <Label Text="Cosa vuoi allenare oggi?"
                       FontSize="18" FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}"
                       HorizontalTextAlignment="Center" />
                <Label Text="Cerca un esercizio per nome o gruppo muscolare."
                       FontSize="13" TextColor="{StaticResource TextSecondary}"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </Grid>

    </Grid>

</ContentPage>
