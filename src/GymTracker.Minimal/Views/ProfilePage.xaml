<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:GymTracker.Minimal.ViewModels"
    x:Class="GymTracker.Minimal.Views.ProfilePage"
    x:DataType="vm:ProfileViewModel"
    Title="Profilo">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="20">

            <!-- Avatar -->
            <VerticalStackLayout HorizontalOptions="Center" Spacing="8">
                <Border Style="{StaticResource Card}"
                        HeightRequest="80" WidthRequest="80"
                        StrokeShape="RoundRectangle 40" Padding="0"
                        HorizontalOptions="Center">
                    <Label Text="🏋️" FontSize="36"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                <Label Text="{Binding Username}" FontSize="20" FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}" HorizontalTextAlignment="Center" />
                <Label Text="{Binding Email}" FontSize="13" TextColor="{StaticResource TextSecondary}"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <!-- Stats -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Allenamenti" FontSize="12" TextColor="{StaticResource TextSecondary}" />
                        <Label Text="0" FontSize="28" FontAttributes="Bold" TextColor="{StaticResource Accent}" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Volume" FontSize="12" TextColor="{StaticResource TextSecondary}" />
                        <Label Text="0 kg" FontSize="28" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Amici" FontSize="12" TextColor="{StaticResource TextSecondary}" />
                        <Label Text="0" FontSize="28" FontAttributes="Bold" TextColor="{StaticResource Accent}" />
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource Card}">
                    <VerticalStackLayout Spacing="2">
                        <Label Text="Streak" FontSize="12" TextColor="{StaticResource TextSecondary}" />
                        <Label Text="0 gg" FontSize="28" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Button Text="ESCI" BackgroundColor="{StaticResource ErrorRed}"
                    TextColor="White" CornerRadius="8" HeightRequest="44" />

            <Label Text="GymTracker v1.0" FontSize="11"
                   TextColor="{StaticResource TextSecondary}"
                   HorizontalTextAlignment="Center" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
