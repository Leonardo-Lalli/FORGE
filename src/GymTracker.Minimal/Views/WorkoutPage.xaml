<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:GymTracker.Minimal.ViewModels"
    x:Class="GymTracker.Minimal.Views.WorkoutPage"
    x:DataType="vm:WorkoutViewModel"
    Title="Workout">

    <Grid RowDefinitions="*" Padding="16">

        <VerticalStackLayout IsVisible="{Binding IsEmptyState}"
                             VerticalOptions="Center" Spacing="24">
            <Label Text="💪" FontSize="64" HorizontalTextAlignment="Center" />
            <Label Text="Pronto ad allenarti?"
                   FontSize="22" FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}"
                   HorizontalTextAlignment="Center" />
            <Label Text="Avvia un nuovo allenamento e registra le tue serie."
                   FontSize="14" TextColor="{StaticResource TextSecondary}"
                   HorizontalTextAlignment="Center" />
            <Button Text="INIZIA ALLENAMENTO" Style="{StaticResource PrimaryButton}"
                    HorizontalOptions="Center" WidthRequest="240"
                    Command="{Binding StartWorkoutCommand}" />
        </VerticalStackLayout>

        <VerticalStackLayout IsVisible="{Binding HasData}"
                             VerticalOptions="Center" Spacing="16">
            <Label Text="{Binding WorkoutTitle}" FontSize="20" FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}" HorizontalTextAlignment="Center" />
            <Button Text="AGGIUNGI ESERCIZIO" Style="{StaticResource SecondaryButton}"
                    HorizontalOptions="Center" />
        </VerticalStackLayout>

    </Grid>

</ContentPage>
