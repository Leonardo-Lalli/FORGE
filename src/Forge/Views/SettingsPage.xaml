<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:Forge.ViewModels"
    x:Class="Forge.Views.SettingsPage"
    x:DataType="vm:SettingsViewModel"
    Title="Settings"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*" BackgroundColor="{DynamicResource Surface}">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Padding="24,20">
            <Border Grid.Column="0" BackgroundColor="{DynamicResource SurfaceContainer}"
                    StrokeShape="RoundRectangle 999" WidthRequest="40" HeightRequest="40" Padding="0"
                    Stroke="{DynamicResource OutlineVariant}" StrokeThickness="0.5">
                <Label Text="←" FontSize="18" TextColor="{DynamicResource OnSurface}"
                       HorizontalOptions="Center" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </Border>
            <Label Grid.Column="1" Text="Impostazioni"
                   FontFamily="OpenSansSemibold" FontSize="18" FontAttributes="Bold"
                   TextColor="{DynamicResource OnSurface}"
                   HorizontalOptions="Center" VerticalOptions="Center" />
        </Grid>

        <ScrollView Grid.Row="1" Padding="24,8,24,100">
            <VerticalStackLayout Spacing="16">

                <!-- Appearance Section -->
                <Label Text="ASPETTO"
                       FontFamily="OpenSansSemibold" FontSize="11" FontAttributes="Bold"
                       TextColor="{DynamicResource TextSecondary}"
                       CharacterSpacing="0.8" Margin="0,8,0,0" />

                <!-- Dark Mode Toggle -->
                <Border BackgroundColor="{DynamicResource SurfaceContainerHigh}"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{DynamicResource OutlineVariant}" StrokeThickness="1"
                        Padding="16">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding CycleThemeCommand}" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="4">
                            <Label Text="Tema"
                                   FontFamily="OpenSansSemibold" FontSize="16" FontAttributes="Bold"
                                   TextColor="{DynamicResource OnSurface}" />
                            <Label Text="Chiaro / Scuro / Auto (segue sistema)"
                                   FontFamily="OpenSansRegular" FontSize="13"
                                   TextColor="{DynamicResource TextSecondary}" />
                        </VerticalStackLayout>
                        <Border Grid.Column="1" BackgroundColor="{DynamicResource PrimaryContainer}"
                                StrokeShape="RoundRectangle 8" Padding="12,6"
                                VerticalOptions="Center">
                            <Label Text="{Binding ThemeLabel}"
                                   FontFamily="OpenSansSemibold" FontSize="12"
                                   TextColor="{DynamicResource Primary}" />
                        </Border>
                    </Grid>
                </Border>

                <!-- Language -->
                <Label Text="LINGUA"
                       FontFamily="OpenSansSemibold" FontSize="11" FontAttributes="Bold"
                       TextColor="{DynamicResource TextSecondary}"
                       CharacterSpacing="0.8" Margin="0,8,0,0" />
                <Border BackgroundColor="{DynamicResource SurfaceContainerHigh}"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{DynamicResource OutlineVariant}" StrokeThickness="1"
                        Padding="16">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Lingua Esercizi"
                               FontFamily="OpenSansSemibold" FontSize="16" FontAttributes="Bold"
                               TextColor="{DynamicResource OnSurface}" />
                        <FlexLayout Wrap="Wrap">
                            <Border Padding="12,8" Margin="0,0,8,0"
                                    StrokeShape="RoundRectangle 999"
                                    Stroke="{DynamicResource Outline}" StrokeThickness="1"
                                    BackgroundColor="Transparent">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsItalian}" Value="True">
                                        <Setter Property="BackgroundColor" Value="{DynamicResource Primary}" />
                                        <Setter Property="Stroke" Value="{DynamicResource Primary}" />
                                    </DataTrigger>
                                </Border.Triggers>
                                <Label Text="🇮🇹 Italiano" FontFamily="Lexend" FontSize="14"
                                       TextColor="{DynamicResource OnSurface}">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsItalian}" Value="True">
                                            <Setter Property="TextColor" Value="{DynamicResource OnPrimary}" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SetItalianCommand}" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </Border>
                            <Border Padding="12,8"
                                    StrokeShape="RoundRectangle 999"
                                    Stroke="{DynamicResource Outline}" StrokeThickness="1"
                                    BackgroundColor="Transparent">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsEnglish}" Value="True">
                                        <Setter Property="BackgroundColor" Value="{DynamicResource Primary}" />
                                        <Setter Property="Stroke" Value="{DynamicResource Primary}" />
                                    </DataTrigger>
                                </Border.Triggers>
                                <Label Text="🇬🇧 English" FontFamily="Lexend" FontSize="14"
                                       TextColor="{DynamicResource OnSurface}">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label" Binding="{Binding IsEnglish}" Value="True">
                                            <Setter Property="TextColor" Value="{DynamicResource OnPrimary}" />
                                        </DataTrigger>
                                    </Label.Triggers>
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SetEnglishCommand}" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </Border>
                        </FlexLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Account Section -->
                <Label Text="DATI"
                       FontFamily="OpenSansSemibold" FontSize="11" FontAttributes="Bold"
                       TextColor="{DynamicResource TextSecondary}"
                       CharacterSpacing="0.8" Margin="0,8,0,0" />

                <!-- Import CSV -->
                <Border BackgroundColor="{DynamicResource SurfaceContainerHigh}"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{DynamicResource OutlineVariant}" StrokeThickness="1"
                        Padding="16">
                    <VerticalStackLayout Spacing="8">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Importa CSV"
                                   FontFamily="OpenSansSemibold" FontSize="16" FontAttributes="Bold"
                                   TextColor="{DynamicResource OnSurface}" />
                            <Label Text="Importa allenamenti da altre app (Date,WorkoutName,ExerciseName,Sets,Reps,WeightKg,Notes)"
                                   FontFamily="OpenSansRegular" FontSize="13"
                                   TextColor="{DynamicResource TextSecondary}" />
                        </VerticalStackLayout>
                        <Button Text="IMPORTA CSV"
                                BackgroundColor="{DynamicResource Primary}"
                                TextColor="{DynamicResource OnPrimary}"
                                FontFamily="OpenSansSemibold" FontSize="14" FontAttributes="Bold"
                                HeightRequest="44" CornerRadius="8"
                                Command="{Binding ImportCsvCommand}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Export CSV -->
                <Border BackgroundColor="{DynamicResource SurfaceContainerHigh}"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{DynamicResource OutlineVariant}" StrokeThickness="1"
                        Padding="16">
                    <VerticalStackLayout Spacing="8">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Esporta CSV"
                                   FontFamily="OpenSansSemibold" FontSize="16" FontAttributes="Bold"
                                   TextColor="{DynamicResource OnSurface}" />
                            <Label Text="Esporta i tuoi allenamenti in formato CSV"
                                   FontFamily="OpenSansRegular" FontSize="13"
                                   TextColor="{DynamicResource TextSecondary}" />
                        </VerticalStackLayout>
                        <Button Text="ESPORTA CSV"
                                BackgroundColor="{DynamicResource Secondary}"
                                TextColor="{DynamicResource OnSecondary}"
                                FontFamily="OpenSansSemibold" FontSize="14" FontAttributes="Bold"
                                HeightRequest="44" CornerRadius="8"
                                Command="{Binding ExportCsvCommand}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Import Status -->
                <Label Text="{Binding ImportStatus}"
                       FontFamily="OpenSansRegular" FontSize="13"
                       TextColor="{DynamicResource TextSecondary}"
                       IsVisible="{Binding HasImportStatus}"
                       HorizontalTextAlignment="Center" />

                <!-- Server Section -->
                <Label Text="SERVER"
                       FontFamily="OpenSansSemibold" FontSize="11" FontAttributes="Bold"
                       TextColor="{DynamicResource TextSecondary}"
                       CharacterSpacing="0.8" Margin="0,8,0,0" />

                <Border BackgroundColor="{DynamicResource SurfaceContainerHigh}"
                        StrokeShape="RoundRectangle 12"
                        Stroke="{DynamicResource OutlineVariant}" StrokeThickness="1"
                        Padding="16">
                    <VerticalStackLayout Spacing="10">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="URL PocketBase"
                                   FontFamily="OpenSansSemibold" FontSize="16" FontAttributes="Bold"
                                   TextColor="{DynamicResource OnSurface}" />
                            <Label Text="Inserisci l'URL del tuo server PocketBase (es. http://192.168.1.50:8090). Lascia vuoto per usare il server predefinito."
                                   FontFamily="OpenSansRegular" FontSize="12"
                                   TextColor="{DynamicResource TextSecondary}" />
                        </VerticalStackLayout>
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <Border Grid.Column="0"
                                    BackgroundColor="{DynamicResource SurfaceContainer}"
                                    StrokeShape="RoundRectangle 8"
                                    Stroke="{DynamicResource OutlineVariant}" StrokeThickness="1"
                                    Padding="12,4">
                                <Entry Text="{Binding ServerUrl}"
                                       Placeholder="http://192.168.1.50:8090"
                                       FontFamily="Inter" FontSize="14"
                                       TextColor="{DynamicResource OnSurface}"
                                       PlaceholderColor="{DynamicResource Outline}"
                                       BackgroundColor="Transparent"
                                       Keyboard="Url" />
                            </Border>
                            <Button Grid.Column="1" Text="SALVA"
                                    BackgroundColor="{DynamicResource Primary}"
                                    TextColor="{DynamicResource OnPrimary}"
                                    FontFamily="OpenSansSemibold" FontSize="13"
                                    HeightRequest="44" CornerRadius="8" Padding="16,0"
                                    Command="{Binding SaveServerUrlCommand}" />
                        </Grid>
                        <Label Text="{Binding ServerStatus}"
                               FontFamily="OpenSansRegular" FontSize="12"
                               TextColor="{DynamicResource LimeGreen}"
                               IsVisible="{Binding HasServerStatus}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Account Section -->
                <Label Text="ACCOUNT"
                       FontFamily="OpenSansSemibold" FontSize="11" FontAttributes="Bold"
                       TextColor="{DynamicResource TextSecondary}"
                       CharacterSpacing="0.8" Margin="0,8,0,0" />

                <!-- Logout Button -->
                <Button Text="LOGOUT"
                        BackgroundColor="{DynamicResource Error}"
                        TextColor="{DynamicResource OnError}"
                        FontFamily="OpenSansSemibold" FontSize="16" FontAttributes="Bold"
                        HeightRequest="52" CornerRadius="12"
                        Command="{Binding LogoutCommand}" />

                <!-- Attributions -->
                <Label Text="Exercise data by ExerciseDB (free-exercise-db)"
                       FontFamily="Inter" FontSize="10"
                       TextColor="{DynamicResource TextSecondary}"
                       HorizontalTextAlignment="Center"
                       Margin="0,24,0,0"
                       Opacity="0.5" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
