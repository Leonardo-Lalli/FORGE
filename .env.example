# FORGE Configuration
# Copia questo file come .env e inserisci l'URL del tuo server PocketBase.
# Il file .env è escluso da Git (.gitignore). Non committare mai URL reali.

POCKETBASE_URL=https://tuo-server.duckdns.org

# Docker — PocketBase admin auto-creato al primo avvio (cambia subito!)
# PB_ADMIN_EMAIL=admin@forge.local
# PB_ADMIN_PASSWORD=forgeadmin123
# PB_ENCRYPTION_KEY=
